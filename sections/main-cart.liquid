<div class="cart-page page-width section-padding">
  <h1 class="cart-page__title">{{ 'cart.general.title' | t }}</h1>

  {%- if cart.item_count > 0 -%}
    {%- form 'cart', cart, class: 'cart-form' -%}
      <table class="cart-table">
        <thead class="cart-table__head">
          <tr>
            <th class="cart-table__cell" scope="col">Producto</th>
            <th class="cart-table__cell" scope="col">Precio</th>
            <th class="cart-table__cell" scope="col">Cantidad</th>
            <th class="cart-table__cell" scope="col">Total</th>
          </tr>
        </thead>
        <tbody>
          {%- for item in cart.items -%}
            <tr class="cart-table__row">
              <td class="cart-table__cell cart-table__cell--product">
                <div class="cart-item">
                  {%- if item.image -%}
                    <img
                      src="{{ item.image | image_url: width: 100 }}"
                      alt="{{ item.image.alt | escape }}"
                      width="100"
                      height="100"
                      loading="lazy"
                      class="cart-item__image"
                    >
                  {%- endif -%}
                  <div class="cart-item__info">
                    <a href="{{ item.url }}" class="cart-item__title">{{ item.product.title }}</a>
                    {%- if item.variant.title != 'Default Title' -%}
                      <p class="cart-item__variant">{{ item.variant.title }}</p>
                    {%- endif -%}
                    <a href="{{ item.url_to_remove }}" class="cart-item__remove">Eliminar</a>
                  </div>
                </div>
              </td>
              <td class="cart-table__cell">{{ item.price | money }}</td>
              <td class="cart-table__cell">
                <input
                  type="number"
                  name="updates[]"
                  id="updates_{{ item.key }}"
                  value="{{ item.quantity }}"
                  min="0"
                  class="cart-item__qty"
                >
              </td>
              <td class="cart-table__cell">{{ item.line_price | money }}</td>
            </tr>
          {%- endfor -%}
        </tbody>
      </table>

      <div class="cart-footer">
        <div class="cart-footer__subtotal">
          <span>Subtotal</span>
          <span>{{ cart.total_price | money }}</span>
        </div>
        <p class="cart-footer__note">Impuestos y envío se calculan en el pago</p>
        <button type="submit" name="checkout" class="btn cart-footer__checkout">
          Finalizar compra
        </button>
      </div>
    {%- endform -%}
  {%- else -%}
    <div class="cart-empty">
      <p>{{ 'cart.general.empty' | t }}</p>
      <a href="{{ routes.all_products_collection_url }}" class="btn">{{ 'cart.general.continue_browsing' | t }}</a>
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Carrito",
  "tag": "section",
  "class": "section-main-cart",
  "settings": []
}
{% endschema %}
