<div class="password-page page-width">
  <div class="password-page__header">
    <h1 class="password-page__logo">
      {%- if settings.logo != blank -%}
        <img
          src="{{ settings.logo | image_url: width: 200 }}"
          alt="{{ shop.name | escape }}"
          width="200"
          height="auto"
          loading="eager"
        >
      {%- else -%}
        {{ shop.name }}
      {%- endif -%}
    </h1>
  </div>

  <div class="password-page__body">
    {%- if section.settings.heading != blank -%}
      <h2 class="password-page__heading">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <div class="password-page__subheading rte">{{ section.settings.subheading }}</div>
    {%- endif -%}

    {%- if section.settings.show_newsletter -%}
      {%- form 'customer', class: 'password-page__newsletter-form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter,password-page">
        <div class="password-page__newsletter-input-wrap">
          <input
            type="email"
            name="contact[email]"
            id="PasswordEmail"
            autocorrect="off"
            autocapitalize="off"
            autocomplete="email"
            placeholder="{{ section.settings.email_placeholder | escape }}"
            required
            class="password-page__email-input"
          >
          <button type="submit" class="btn">
            {{ section.settings.newsletter_button_label | escape }}
          </button>
        </div>
        {%- if form.posted_successfully? -%}
          <p class="password-page__success">{{ 'general.password_page.newsletter_confirm_text' | t }}</p>
        {%- endif -%}
      {%- endform -%}
    {%- endif -%}

    {%- if section.settings.show_share_password -%}
      <div class="password-page__admin-link">
        {{ 'general.password_page.admin_link_html' | t }}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Página de contraseña",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Encabezado",
      "default": "Próximamente"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Descripción",
      "default": "<p>Estamos preparando algo increíble. ¡Vuelve pronto!</p>"
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "Mostrar formulario de email",
      "default": true
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Texto de placeholder del email",
      "default": "Tu correo electrónico"
    },
    {
      "type": "text",
      "id": "newsletter_button_label",
      "label": "Texto del botón",
      "default": "Notifícame"
    },
    {
      "type": "checkbox",
      "id": "show_share_password",
      "label": "Mostrar enlace de administrador",
      "default": true
    }
  ]
}
{% endschema %}
