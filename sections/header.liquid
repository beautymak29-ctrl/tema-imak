{% comment %} Header estilo Apple – nav translucido oscuro {% endcomment %}
<header class="hd" id="shopify-section-header" data-sticky="{{ section.settings.sticky_header_type }}">
  <div class="hd__inner page-width">
    {%- comment -%} Logo / Home icon {%- endcomment -%}
    <a href="{{ routes.root_url }}" class="hd__logo" aria-label="{{ shop.name }}">
      {%- if section.settings.logo != blank -%}
        <img
          src="{{ section.settings.logo | image_url: width: section.settings.logo_width }}"
          alt="{{ section.settings.logo.alt | default: shop.name | escape }}"
          width="{{ section.settings.logo_width }}"
          height="auto"
          loading="eager"
          class="hd__logo-img"
        >
      {%- else -%}
        <svg class="hd__apple-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 17 48" width="14" height="44" aria-hidden="true"><path d="M15.5 24.076c-.028-3.17 2.584-4.692 2.7-4.763a5.877 5.877 0 0 0-4.632-2.504c-1.97-.2-3.848 1.16-4.85 1.16-1 0-2.546-1.13-4.184-1.1a6.158 6.158 0 0 0-5.183 3.161c-2.21 3.834-.566 9.515 1.588 12.627 1.053 1.524 2.31 3.235 3.96 3.174 1.588-.064 2.188-1.028 4.107-1.028 1.92 0 2.456 1.028 4.132.996 1.71-.028 2.8-1.553 3.838-3.083a12.696 12.696 0 0 0 1.74-3.567 5.573 5.573 0 0 1-3.216-5.073z" fill="currentColor"/></svg>
      {%- endif -%}
    </a>

    {%- comment -%} Nav principal {%- endcomment -%}
    <nav class="hd__nav" role="navigation" aria-label="Principal">
      <ul class="hd__nav-list" role="list">
        {%- for link in linklists[section.settings.menu].links -%}
          <li class="hd__nav-item">
            <a
              href="{{ link.url }}"
              class="hd__nav-link{% if link.active %} hd__nav-link--active{% endif %}"
              {% if link.current %}aria-current="page"{% endif %}
            >
              {{ link.title | escape }}
            </a>
          </li>
        {%- endfor -%}
      </ul>
    </nav>

    {%- comment -%} Iconos derecha {%- endcomment -%}
    <div class="hd__actions">
      {%- comment -%} Hamburguesa mobile {%- endcomment -%}
      <button class="hd__burger" aria-label="Menú" aria-expanded="false" aria-controls="hd-mobile-nav">
        <span class="hd__burger-line"></span>
        <span class="hd__burger-line"></span>
      </button>
    </div>
  </div>

  {%- comment -%} Mobile nav panel {%- endcomment -%}
  <div class="hd__mobile" id="hd-mobile-nav" aria-hidden="true">
    <nav class="hd__mobile-inner page-width">
      <ul class="hd__mobile-list" role="list">
        {%- for link in linklists[section.settings.menu].links -%}
          <li class="hd__mobile-item">
            <a href="{{ link.url }}" class="hd__mobile-link{% if link.active %} hd__mobile-link--active{% endif %}">
              {{ link.title | escape }}
            </a>
          </li>
        {%- endfor -%}
      </ul>
    </nav>
  </div>
</header>

<script>
(function(){
  var hdr = document.querySelector('.hd');
  var burger = hdr.querySelector('.hd__burger');
  var panel = hdr.querySelector('.hd__mobile');
  burger.addEventListener('click', function(){
    var open = burger.getAttribute('aria-expanded') === 'true';
    burger.setAttribute('aria-expanded', String(!open));
    panel.setAttribute('aria-hidden', String(open));
    burger.classList.toggle('hd__burger--open');
    hdr.classList.toggle('hd--mobile-open');
  });

  /* Sticky on scroll up */
  var sticky = hdr.dataset.sticky;
  if (sticky === 'none') return;
  var lastY = 0;
  window.addEventListener('scroll', function(){
    var y = window.pageYOffset;
    if (sticky === 'always') {
      hdr.classList.add('hd--stuck');
    } else {
      if (y < lastY && y > 44) {
        hdr.classList.add('hd--stuck');
      } else {
        hdr.classList.remove('hd--stuck');
      }
    }
    lastY = y;
  }, {passive: true});
})();
</script>

{% schema %}
{
  "name": "Header",
  "class": "section-header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 50,
      "max": 300,
      "step": 10,
      "unit": "px",
      "label": "Ancho del logo",
      "default": 100
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menú",
      "default": "main-menu"
    },
    {
      "type": "select",
      "id": "sticky_header_type",
      "options": [
        { "value": "none", "label": "Ninguno" },
        { "value": "on-scroll-up", "label": "Al desplazar hacia arriba" },
        { "value": "always", "label": "Siempre" }
      ],
      "default": "on-scroll-up",
      "label": "Encabezado fijo"
    }
  ]
}
{% endschema %}
