</section>

<script>
(function () {
  /* Open modal */
  document.querySelectorAll('[data-ptb-open]').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var id = btn.getAttribute('data-ptb-open');
      var modal = document.getElementById('ptb-modal-' + id);
      if (modal) {
        modal.hidden = false;
        document.body.style.overflow = 'hidden';
        modal.querySelector('.ptb-modal__close').focus();
      }
    });
  });
  /* Close modal */
  document.querySelectorAll('[data-ptb-close]').forEach(function (el) {
    el.addEventListener('click', function () {
      var id = el.getAttribute('data-ptb-close');
      var modal = document.getElementById('ptb-modal-' + id);
      if (modal) {
        modal.hidden = true;
        document.body.style.overflow = '';
      }
    });
  });
  /* Close on Escape */
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') {
      document.querySelectorAll('.ptb-modal:not([hidden])').forEach(function (m) {
        m.hidden = true;
        document.body.style.overflow = '';
      });
    }
  });
})();
</script>

{% schema %}
{
  "name": "Barra de beneficios",
  "tag": "section",
  "class": "section-product-trust-bar",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "T\u00edtulo de la secci\u00f3n (opcional)"
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Beneficio",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "\u00cdcono",
          "options": [
            { "value": "card",    "label": "Tarjeta / Convenio" },
            { "value": "percent", "label": "Porcentaje / Sin intereses" },
            { "value": "savings", "label": "Dinero / Plan ahorro" },
            { "value": "pin",     "label": "Ubicaci\u00f3n / Vis\u00edtanos" },
            { "value": "star",    "label": "Estrella / Destacado" },
            { "value": "shield",  "label": "Escudo / Garant\u00eda" }
          ],
          "default": "card"
        },
        {
          "type": "text",
          "id": "title",
          "label": "T\u00edtulo",
          "default": "Beneficio"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Descripci\u00f3n corta"
        },
        {
