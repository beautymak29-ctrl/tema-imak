<section class="ptb-section section-{{ section.id }}">
  <div class="page-width">
    {%- if section.settings.title != blank -%}
      <h2 class="ptb-title">{{ section.settings.title | escape }}</h2>
    {%- endif -%}
    <ul class="ptb-list" role="list">
      {%- for block in section.blocks -%}
        <li class="ptb-item" {{ block.shopify_attributes }}>
          <button type="button" class="ptb-item__trigger" aria-haspopup="dialog" data-ptb-open="{{ block.id }}">
            <div class="ptb-item__icon-wrap" aria-hidden="true">
              {%- case block.settings.icon -%}
                {%- when 'card' -%}
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
                {%- when 'percent' -%}
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="5" x2="5" y2="19"/><circle cx="6.5" cy="6.5" r="2.5"/><circle cx="17.5" cy="17.5" r="2.5"/></svg>
                {%- when 'savings' -%}
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                {%- when 'pin' -%}
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                {%- when 'star' -%}
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                {%- when 'shield' -%}
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                {%- else -%}
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 8 12 12 14 14"/></svg>
              {%- endcase -%}
            </div>
            <strong class="ptb-item__title">{{ block.settings.title | escape }}</strong>
            {%- if block.settings.description != blank -%}
              <p class="ptb-item__desc">{{ block.settings.description | escape }}</p>
            {%- endif -%}
          </button>
        </li>

        {%- comment -%} Modal for this benefit {%- endcomment -%}
        <div class="ptb-modal" id="ptb-modal-{{ block.id }}" role="dialog" aria-modal="true" aria-labelledby="ptb-modal-title-{{ block.id }}" hidden>
          <div class="ptb-modal__overlay" data-ptb-close="{{ block.id }}"></div>
          <div class="ptb-modal__container">
            <div class="ptb-modal__header">
              <div class="ptb-modal__icon-wrap" aria-hidden="true">
                {%- case block.settings.icon -%}
                  {%- when 'card' -%}
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
                  {%- when 'percent' -%}
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="5" x2="5" y2="19"/><circle cx="6.5" cy="6.5" r="2.5"/><circle cx="17.5" cy="17.5" r="2.5"/></svg>
                  {%- when 'savings' -%}
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                  {%- when 'pin' -%}
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                  {%- when 'star' -%}
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                  {%- when 'shield' -%}
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                  {%- else -%}
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 8 12 12 14 14"/></svg>
                {%- endcase -%}
              </div>
              <h3 class="ptb-modal__title" id="ptb-modal-title-{{ block.id }}">{{ block.settings.title | escape }}</h3>
              <button type="button" class="ptb-modal__close" data-ptb-close="{{ block.id }}" aria-label="Cerrar">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
              </button>
            </div>
            <div class="ptb-modal__body rte">
              {%- if block.settings.detail_content != blank -%}
                {{ block.settings.detail_content }}
              {%- endif -%}

              {%- if block.settings.show_efectiva -%}
                <div class="ptb-efectiva">
                  <div class="ptb-efectiva__header">
                    <span class="ptb-efectiva__logo" aria-label="Efectiva">
                      <span class="ptb-efectiva__logo-e">E</span>fectiva
                    </span>
                    <span class="ptb-efectiva__badge">Financiamiento aprobado</span>
                  </div>
                  <p class="ptb-efectiva__intro">
                    Si cumples los requisitos y tu crédito es aprobado, <strong>Efectiva te financia</strong> para que estrenes tu equipo Apple completamente nuevo. Sin bancos, sin complicaciones.
                  </p>
                  <div class="ptb-efectiva__steps">
                    <div class="ptb-efectiva__step">
                      <span class="ptb-efectiva__step-num">1</span>
                      <div>
                        <strong>Evalúa tu crédito</strong>
                        <p>Tráenos tu DNI y en minutos sabrás si calificas.</p>
                      </div>
                    </div>
                    <div class="ptb-efectiva__step">
                      <span class="ptb-efectiva__step-num">2</span>
                      <div>
                        <strong>Elige tu equipo</strong>
                        <p>Selecciona el producto Apple que quieras de nuestra tienda.</p>
                      </div>
                    </div>
                    <div class="ptb-efectiva__step">
                      <span class="ptb-efectiva__step-num">3</span>
                      <div>
                        <strong>Llévatelo hoy</strong>
                        <p>Efectiva se encarga del financiamiento y tú disfrutas tu equipo desde el día uno.</p>
                      </div>
                    </div>
                  </div>
                  <p class="ptb-efectiva__note">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
                    Sujeto a evaluación crediticia. Consulta condiciones en tienda.
                  </p>
                </div>
              {%- endif -%}

              {%- if block.settings.show_pandero -%}
                <div class="ptb-pandero">
                  <div class="ptb-pandero__header">
                    <div class="ptb-pandero__icon-circle">
                      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M16 8l-8 8"/><path d="M8.5 8H8v.5"/><path d="M16 15.5v.5h-.5"/></svg>
                    </div>
                    <div>
                      <span class="ptb-pandero__title">Plan Ahorro <span class="ptb-pandero__aka">(Pandero)</span></span>
                      <span class="ptb-pandero__tagline">Tu equipo Apple, a tu ritmo</span>
                    </div>
                  </div>

                  <p class="ptb-pandero__intro">
                    Ahorra mes a mes con cuotas cómodas y, al completar el monto total, <strong>estrena tu equipo Apple completamente nuevo</strong>. Sin intereses, sin deudas, a tu propio ritmo.
                  </p>

                  <div class="ptb-pandero__timeline">
                    <div class="ptb-pandero__tl-item">
                      <div class="ptb-pandero__tl-dot"></div>
                      <div class="ptb-pandero__tl-content">
                        <strong>Inscríbete</strong>
                        <p>Ven a nuestra tienda, elige tu equipo y te asignamos un plan de ahorro a tu medida.</p>
                      </div>
                    </div>
                    <div class="ptb-pandero__tl-item">
                      <div class="ptb-pandero__tl-dot"></div>
                      <div class="ptb-pandero__tl-content">
                        <strong>Ahorra mes a mes</strong>
                        <p>Realizas pagos mensuales fijos y accesibles. Sin sorpresas, sin recargos.</p>
                      </div>
                    </div>
                    <div class="ptb-pandero__tl-item">
                      <div class="ptb-pandero__tl-dot"></div>
                      <div class="ptb-pandero__tl-content">
                        <strong>Completa y estrena</strong>
                        <p>Al completar tu plan, te llevas tu equipo nuevo de paquete. ¡Así de simple!</p>
                      </div>
                    </div>
                  </div>

                  <div class="ptb-pandero__highlight">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                    <span>La forma más inteligente de planificar tu compra <strong>sin endeudarte</strong></span>
                  </div>
                </div>
              {%- endif -%}

              {%- if block.settings.show_location -%}
                <div class="ptb-location">
                  <div class="ptb-location__map-wrap">
                    <iframe
                      class="ptb-location__map"
                      src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d987.5!2d-74.5393!3d-8.3791!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x91a1b5b5b5b5b5b5%3A0x0!2sJr.+Atahualpa+183%2C+Pucallpa!5e0!3m2!1ses!2spe!4v1"
                      width="100%"
                      height="180"
                      style="border:0;"
                      allowfullscreen=""
                      loading="lazy"
                      referrerpolicy="no-referrer-when-downgrade"
                      title="Ubicación de IMAK"
                    ></iframe>
                  </div>

                  <div class="ptb-location__info">
                    <div class="ptb-location__address">
                      <div class="ptb-location__pin">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                      </div>
                      <div>
                        <strong class="ptb-location__street">Jr. Atahualpa 183</strong>
                        <span class="ptb-location__city">Pucallpa, Ucayali – Perú</span>
                      </div>
                    </div>

                    <div class="ptb-location__details">
                      <div class="ptb-location__detail">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                        <div>
                          <strong>Horario</strong>
                          <p>Lun–Dom: 10:00 AM – 8:00 PM</p>
                        </div>
                      </div>
                      <div class="ptb-location__detail">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                        <div>
                          <strong>Teléfono</strong>
                          <p>990 802 163</p>
                        </div>
                      </div>
                    </div>

                    <a href="https://maps.google.com/?q=Jr.+Atahualpa+183,+Pucallpa,+Per%C3%BA" target="_blank" rel="noopener noreferrer" class="ptb-location__cta">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="3 11 22 2 13 21 11 13 3 11"/></svg>
                      Cómo llegar
                    </a>
                  </div>
                </div>
              {%- endif -%}

              {%- if block.settings.show_card_logos -%}
                <div class="ptb-cards">
                  <p class="ptb-cards__headline">
                    <svg class="ptb-cards__lock" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                    Aceptamos hasta <strong>6 cuotas sin intereses</strong> con estas tarjetas
                  </p>
                  <div class="ptb-cards__grid">
                    <div class="ptb-cards__item">
                      <svg viewBox="0 0 780 500" width="56" height="36" aria-label="Visa">
                        <rect width="780" height="500" rx="40" fill="#fff" stroke="#e5e5e5"/>
                        <path d="M293.2 348.7l33.4-195.8h53.4l-33.4 195.8zM540.7 157.2c-10.6-4-27.1-8.3-47.8-8.3-52.7 0-89.8 26.6-90.1 64.7-.3 28.2 26.5 43.9 46.8 53.3 20.8 9.6 27.8 15.7 27.7 24.3-.1 13.1-16.6 19.1-32 19.1-21.4 0-32.7-3-50.3-10.2l-6.9-3.1-7.5 44c12.5 5.5 35.6 10.2 59.5 10.5 56.1 0 92.5-26.3 92.9-67 .2-22.3-14-39.3-44.8-53.3-18.7-9.1-30.1-15.1-30-24.3 0-8.1 9.7-16.8 30.6-16.8 17.5-.3 30.1 3.5 40 7.5l4.8 2.3 7.3-42.7zM651 152.9h-41.2c-12.8 0-22.3 3.5-27.9 16.2l-79.2 179.6h56.1s9.2-24.2 11.2-29.5h68.5c1.6 6.9 6.5 29.5 6.5 29.5h49.6L651 152.9zm-65.7 125.9c4.4-11.3 21.4-54.8 21.4-54.8-.3.5 4.4-11.4 7.1-18.8l3.6 17s10.3 47.1 12.4 56.6h-44.5zM231.4 152.9L179.2 284l-5.6-27.1c-9.7-31.2-39.8-65.1-73.5-82l47.8 171.7 56.5-.1 84.1-193.7h-56.1z" fill="#1a1f71"/>
                        <path d="M119.7 152.9H33.4l-.7 4.1c67 16.2 111.4 55.4 129.7 102.4l-18.7-90.2c-3.2-12.4-12.6-16-24-16.3z" fill="#f7a600"/>
                      </svg>
                    </div>
                    <div class="ptb-cards__item">
                      <svg viewBox="0 0 780 500" width="56" height="36" aria-label="Mastercard">
                        <rect width="780" height="500" rx="40" fill="#fff" stroke="#e5e5e5"/>
                        <circle cx="312" cy="250" r="140" fill="#eb001b"/>
                        <circle cx="468" cy="250" r="140" fill="#f79e1b"/>
                        <path d="M390 138.2c37.2 29.3 61 74.5 61 125.8s-23.8 96.5-61 125.8c-37.2-29.3-61-74.5-61-125.8s23.8-96.5 61-125.8z" fill="#ff5f00"/>
                      </svg>
                    </div>
                    <div class="ptb-cards__item">
                      <svg viewBox="0 0 780 500" width="56" height="36" aria-label="American Express">
                        <rect width="780" height="500" rx="40" fill="#016fd0"/>
                        <text x="390" y="210" text-anchor="middle" fill="#fff" font-family="Arial,Helvetica,sans-serif" font-weight="bold" font-size="110" letter-spacing="8">AMERICAN</text>
                        <text x="390" y="340" text-anchor="middle" fill="#fff" font-family="Arial,Helvetica,sans-serif" font-weight="bold" font-size="110" letter-spacing="8">EXPRESS</text>
                      </svg>
                    </div>
                    <div class="ptb-cards__item">
                      <svg viewBox="0 0 780 500" width="56" height="36" aria-label="Diners Club">
                        <rect width="780" height="500" rx="40" fill="#fff" stroke="#e5e5e5"/>
                        <circle cx="390" cy="230" r="130" fill="none" stroke="#004a97" stroke-width="16"/>
                        <path d="M320 140v180c-42-22-70-66-70-90s28-68 70-90zM460 140v180c42-22 70-66 70-90s-28-68-70-90z" fill="#004a97" opacity=".2"/>
                        <text x="390" y="420" text-anchor="middle" fill="#004a97" font-family="Arial,Helvetica,sans-serif" font-weight="bold" font-size="62" letter-spacing="3">DINERS CLUB</text>
