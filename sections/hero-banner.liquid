{% comment %} Sección Hero / Banner principal {% endcomment %}
{%- assign is_dark = false -%}
{%- if section.settings.background_color == '#000000' or section.settings.background_color == '#000' or section.settings.background_color == '#1d1d1f' or section.settings.background_color == '#111111' -%}
  {%- assign is_dark = true -%}
{%- endif -%}
<section class="hero{% if is_dark %} hero--dark{% endif %}" style="background-color: {{ section.settings.background_color }}; color: {% if is_dark %}#f5f5f7{% else %}#1d1d1f{% endif %};">
  {%- if section.settings.image != blank -%}
    {%- assign mobile_img = section.settings.mobile_image | default: section.settings.image -%}
    <div class="hero__media">
      <img
        srcset="{{ section.settings.image | image_url: width: 750 }} 750w,
                {{ section.settings.image | image_url: width: 1100 }} 1100w,
                {{ section.settings.image | image_url: width: 1500 }} 1500w,
                {{ section.settings.image | image_url: width: 2400 }} 2400w,
                {{ section.settings.image | image_url: width: 3200 }} 3200w"
        sizes="100vw"
        src="{{ section.settings.image | image_url: width: 2400 }}"
        alt="{{ section.settings.image.alt | escape }}"
        width="{{ section.settings.image.width }}"
        height="{{ section.settings.image.height }}"
        loading="eager"
        fetchpriority="high"
        class="hero__image hero__image--desktop"
      >
      <img
        srcset="{{ mobile_img | image_url: width: 400 }} 400w,
                {{ mobile_img | image_url: width: 600 }} 600w,
                {{ mobile_img | image_url: width: 750 }} 750w,
                {{ mobile_img | image_url: width: 900 }} 900w"
        sizes="100vw"
        src="{{ mobile_img | image_url: width: 750 }}"
        alt="{{ mobile_img.alt | escape }}"
        width="{{ mobile_img.width }}"
        height="{{ mobile_img.height }}"
        loading="eager"
        fetchpriority="high"
        class="hero__image hero__image--mobile"
      >
    </div>
  {%- endif -%}

  <div class="hero__content page-width">
    {%- if section.settings.subheading != blank -%}
      <p class="hero__subheading">{{ section.settings.subheading | escape }}</p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h1 class="hero__heading">{{ section.settings.heading | escape }}</h1>
    {%- endif -%}
    {%- if section.settings.text != blank -%}
      <div class="hero__text rte">{{ section.settings.text }}</div>
    {%- endif -%}
    {%- if section.settings.button_label != blank -%}
      <a href="{{ section.settings.button_link }}" class="btn">
        {{ section.settings.button_label | escape }}
      </a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Banner héroe",
  "tag": "section",
  "class": "section-hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen de fondo (escritorio)",
      "info": "Sube una imagen de al menos 2400\u00d71200 px para evitar pixelado"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Imagen de fondo (celular)",
      "info": "Sube una imagen vertical de 750\u00d71200 px. Si se deja vac\u00edo se usa la de escritorio"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Color de fondo",
      "default": "#f3f3f3"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subencabezado",
      "default": "Bienvenido a"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Encabezado",
      "default": "Nuestra tienda"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Descripción",
      "default": "<p>Descubre nuestra colección.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Texto del botón",
      "default": "Ver productos"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Enlace del botón"
    }
  ],
  "presets": [
    {
      "name": "Banner héroe"
    }
  ]
}
{% endschema %}
