  var names = Object.keys(models);
  var selA = document.getElementById('cmp-select-a');
  var selB = document.getElementById('cmp-select-b');
  var table = document.getElementById('cmp-table');

  // Lee imágenes y colores configurados en el editor de tema y los fusiona con los datos hardcoded
  document.querySelectorAll('#cmp-model-imgs-{{ section.id }} [data-model]').forEach(function(el) {
    var modelName = el.getAttribute('data-model');
    if (!models[modelName]) return;
    var colors = [], colorHex = [], colorImgs = [];
    el.querySelectorAll('[data-cname]').forEach(function(s) {
      colors.push(s.getAttribute('data-cname'));
      colorHex.push(s.getAttribute('data-chex') || '#86868b');
      colorImgs.push(s.getAttribute('data-cimg') || '');
    });
    if (colors.length > 0) {
      models[modelName].colors    = colors;
      models[modelName].colorHex  = colorHex;
      models[modelName].colorImgs = colorImgs;
    }
  });

  function escAttr(str) { return String(str).replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;'); }

  function populateOptions() {
    var valA = selA.value;
    var valB = selB.value;

    selA.innerHTML = '<option value="">Selecciona un modelo</option>';
    selB.innerHTML = '<option value="">Selecciona un modelo</option>';

    names.forEach(function(n) {
      if (n !== valB) {
        var o = document.createElement('option');
        o.value = n; o.textContent = n;
        if (n === valA) o.selected = true;
        selA.appendChild(o);
      }
      if (n !== valA) {
        var o2 = document.createElement('option');
        o2.value = n; o2.textContent = n;
        if (n === valB) o2.selected = true;
        selB.appendChild(o2);
      }
    });
  }

  function render() {
    var a = selA.value;
    var b = selB.value;

    if (!a || !b) {
      table.innerHTML = '<p class="cmp-empty">Selecciona dos modelos para comparar.</p>';
      return;
    }

    var mA = models[a];
    var mB = models[b];
    var html = '';

    /* Header con colores y botones */
    html += '<div class="cmp-cols">';
    html += buildHeader(a, mA);
    html += buildHeader(b, mB);
    html += '</div>';

    /* Specs */
    var numCats = mA.specs.length;
    for (var c = 0; c < numCats; c++) {
      var catA = mA.specs[c];
      var catB = mB.specs[c];
      html += '<div class="cmp-cat">';
      html += '<h3 class="cmp-cat__title">' + catA.cat + '</h3>';
      html += '<div class="cmp-cat__rows">';
      var numRows = Math.max(catA.rows.length, catB.rows.length);
      for (var r = 0; r < numRows; r++) {
        var rA = catA.rows[r] || ["—"];
        var rB = catB.rows[r] || ["—"];
        var txtA = rA.join('<br>').replace(/\n/g, '<br>');
        var txtB = rB.join('<br>').replace(/\n/g, '<br>');
        var isNA_A = txtA === 'No disponible';
        var isNA_B = txtB === 'No disponible';
        html += '<div class="cmp-row">';
        html += '<div class="cmp-cell' + (isNA_A ? ' cmp-cell--na' : '') + '">' + txtA + '</div>';
        html += '<div class="cmp-cell' + (isNA_B ? ' cmp-cell--na' : '') + '">' + txtB + '</div>';
        html += '</div>';
      }
      html += '</div></div>';
    }

    table.innerHTML = html;
  }

  function buildHeader(name, model) {
    var firstImg = model.colorImgs && model.colorImgs[0] ? model.colorImgs[0] : '';
    var h = '<div class="cmp-col-header">';
    h += '<div class="cmp-col-header__img-wrap">';
    if (firstImg) {
      h += '<img class="cmp-col-header__img" src="' + firstImg + '" alt="' + escAttr(name) + '" loading="lazy">';
    }
    h += '</div>';
    h += '<h3 class="cmp-col-header__name">' + name + '</h3>';
    h += '<div class="cmp-col-header__colors">';
    model.colors.forEach(function(c, i) {
      var img = model.colorImgs && model.colorImgs[i] ? model.colorImgs[i] : '';
      h += '<button type="button" class="cmp-col-header__swatch' + (i === 0 ? ' is-active' : '') + '"'
        + ' style="background:' + model.colorHex[i] + ';"'
        + ' title="' + escAttr(c) + '"'
        + ' data-img="' + escAttr(img) + '"'
        + ' data-color-name="' + escAttr(c) + '"'
        + '></button>';
    });
    h += '</div>';
    h += '<p class="cmp-col-header__color-label">' + escAttr(model.colors[0] || '') + '</p>';
    h += '</div>';
    return h;
  }

  selA.addEventListener('change', function() { populateOptions(); render(); });
  selB.addEventListener('change', function() { populateOptions(); render(); });

  table.addEventListener('click', function(e) {
    var swatch = e.target.closest && e.target.closest('.cmp-col-header__swatch');
    if (!swatch) return;
    var header = swatch.closest('.cmp-col-header');
    if (!header) return;
    // Actualizar swatch activo
    header.querySelectorAll('.cmp-col-header__swatch').forEach(function(s) { s.classList.remove('is-active'); });
    swatch.classList.add('is-active');
    // Cambiar imagen
    var newSrc = swatch.getAttribute('data-img');
    if (newSrc) {
      var imgEl = header.querySelector('.cmp-col-header__img');
      if (imgEl) {
        imgEl.style.opacity = '0';
        imgEl.src = newSrc;
        imgEl.onload = function() { imgEl.style.opacity = '1'; };
      } else {
        var wrap = header.querySelector('.cmp-col-header__img-wrap');
        if (wrap) {
          var newImg = document.createElement('img');
          newImg.className = 'cmp-col-header__img';
          newImg.src = newSrc;
          newImg.alt = (header.querySelector('.cmp-col-header__name') || {}).textContent || '';
          newImg.loading = 'lazy';
          wrap.appendChild(newImg);
        }
      }
    }
    // Actualizar etiqueta de color
    var label = header.querySelector('.cmp-col-header__color-label');
    if (label) label.textContent = swatch.getAttribute('data-color-name') || '';
  });

  populateOptions();
})();
</script>

