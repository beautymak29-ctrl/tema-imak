<section class="cmp-section section-{{ section.id }}">
  <div class="page-width">

    {%- if section.settings.title != blank -%}
      <h2 class="cmp-title">{{ section.settings.title }}</h2>
    {%- endif -%}

    <div class="cmp-selectors">
      <div class="cmp-selector">
        <select id="cmp-select-a" class="cmp-select" aria-label="Modelo 1">
          <option value="">Selecciona un modelo</option>
        </select>
      </div>
      <div class="cmp-selector">
        <select id="cmp-select-b" class="cmp-select" aria-label="Modelo 2">
          <option value="">Selecciona un modelo</option>
        </select>
      </div>
    </div>

    <div class="cmp-table" id="cmp-table">
      <p class="cmp-empty">Selecciona dos modelos para comparar.</p>
    </div>

  </div>

  {%- comment -%} Datos de imágenes por color — configurables desde el editor de tema {%- endcomment -%}
  <div id="cmp-model-imgs-{{ section.id }}" hidden>
    {%- for block in section.blocks -%}
      <div data-model="{{ block.settings.model_key | escape }}" {{ block.shopify_attributes }}>
        {%- for i in (1..5) -%}
          {%- assign cn = 'color_' | append: i | append: '_name' -%}
          {%- assign ch = 'color_' | append: i | append: '_hex' -%}
          {%- assign ci = 'color_' | append: i | append: '_image' -%}
          {%- if block.settings[cn] != blank -%}
            <span
              data-cname="{{ block.settings[cn] | escape }}"
              data-chex="{{ block.settings[ch] | default: '#86868b' | escape }}"
              data-cimg="{%- if block.settings[ci] != blank -%}{{ block.settings[ci] | image_url: width: 800 }}{%- endif -%}"
            ></span>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endfor -%}
  </div>

</section>

