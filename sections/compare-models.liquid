  var names = Object.keys(models);
  var selA = document.getElementById('cmp-select-a');
  var selB = document.getElementById('cmp-select-b');
  var table = document.getElementById('cmp-table');

  function populateOptions() {
    var valA = selA.value;
    var valB = selB.value;

    selA.innerHTML = '<option value="">Selecciona un modelo</option>';
    selB.innerHTML = '<option value="">Selecciona un modelo</option>';

    names.forEach(function(n) {
      if (n !== valB) {
        var o = document.createElement('option');
        o.value = n; o.textContent = n;
        if (n === valA) o.selected = true;
        selA.appendChild(o);
      }
      if (n !== valA) {
        var o2 = document.createElement('option');
        o2.value = n; o2.textContent = n;
        if (n === valB) o2.selected = true;
        selB.appendChild(o2);
      }
    });
  }

  function render() {
    var a = selA.value;
    var b = selB.value;

    if (!a || !b) {
      table.innerHTML = '<p class="cmp-empty">Selecciona dos modelos para comparar.</p>';
      return;
    }

    var mA = models[a];
    var mB = models[b];
    var html = '';

    /* Header con colores y botones */
    html += '<div class="cmp-cols">';
    html += buildHeader(a, mA);
    html += buildHeader(b, mB);
    html += '</div>';

    /* Specs */
    var numCats = mA.specs.length;
    for (var c = 0; c < numCats; c++) {
      var catA = mA.specs[c];
      var catB = mB.specs[c];
      html += '<div class="cmp-cat">';
      html += '<h3 class="cmp-cat__title">' + catA.cat + '</h3>';
      html += '<div class="cmp-cat__rows">';
      var numRows = Math.max(catA.rows.length, catB.rows.length);
      for (var r = 0; r < numRows; r++) {
        var rA = catA.rows[r] || ["—"];
        var rB = catB.rows[r] || ["—"];
        var txtA = rA.join('<br>').replace(/\n/g, '<br>');
        var txtB = rB.join('<br>').replace(/\n/g, '<br>');
        var isNA_A = txtA === 'No disponible';
        var isNA_B = txtB === 'No disponible';
        html += '<div class="cmp-row">';
        html += '<div class="cmp-cell' + (isNA_A ? ' cmp-cell--na' : '') + '">' + txtA + '</div>';
        html += '<div class="cmp-cell' + (isNA_B ? ' cmp-cell--na' : '') + '">' + txtB + '</div>';
        html += '</div>';
      }
      html += '</div></div>';
    }

    table.innerHTML = html;
  }

  function buildHeader(name, model) {
    var h = '<div class="cmp-col-header">';
    h += '<h3 class="cmp-col-header__name">' + name + '</h3>';
    h += '<div class="cmp-col-header__colors">';
    model.colors.forEach(function(c, i) {
      h += '<span class="cmp-col-header__swatch" style="background:' + model.colorHex[i] + ';" title="' + c + '"></span>';
    });
    h += '</div>';
    h += '<a href="#" class="cmp-col-header__btn">Más información</a>';
    h += '</div>';
    return h;
  }

  selA.addEventListener('change', function() { populateOptions(); render(); });
  selB.addEventListener('change', function() { populateOptions(); render(); });

  populateOptions();
})();
</script>

{% schema %}
{
  "name": "Comparar modelos",
  "tag": "section",
  "class": "section-compare-models",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Compara los modelos de iPhone."
    }
  ],
  "presets": [
    {
      "name": "Comparar modelos"
    }
  ]
}
{% endschema %}
