{%- comment -%}
  Apple-style promo cards grid for homepage.
  Blocks can be "full" (100% width) or "half" (50% width, paired automatically).
{%- endcomment -%}

{%- if section.blocks.size > 0 -%}
<section class="hc-section section-{{ section.id }}">
  <div class="hc-grid">
    {%- for block in section.blocks -%}
      {%- assign is_full = block.settings.card_size -%}
      {%- assign is_dark = false -%}
      {%- if block.settings.theme == 'dark' -%}{%- assign is_dark = true -%}{%- endif -%}

      <article class="hc-card {% if is_full == 'full' %}hc-card--full{% else %}hc-card--half{% endif %} {% if is_dark %}hc-card--dark{% else %}hc-card--light{% endif %}" {{ block.shopify_attributes }}>

        <div class="hc-card__content">
          {%- if block.settings.badge != blank -%}
            <span class="hc-card__badge">{{ block.settings.badge | escape }}</span>
          {%- endif -%}

          <h2 class="hc-card__heading">{{ block.settings.heading | escape }}</h2>

          {%- if block.settings.subheading != blank -%}
            <p class="hc-card__subheading">{{ block.settings.subheading }}</p>
          {%- endif -%}

          {%- if block.settings.availability != blank -%}
            <p class="hc-card__availability">{{ block.settings.availability | escape }}</p>
          {%- endif -%}

          <div class="hc-card__links">
            {%- if block.settings.link_1 != blank and block.settings.link_1_label != blank -%}
              <a href="{{ block.settings.link_1 }}" class="hc-card__link hc-card__link--primary">
                {{ block.settings.link_1_label | escape }}
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M4.5 2l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>
            {%- endif -%}
            {%- if block.settings.link_2 != blank and block.settings.link_2_label != blank -%}
              <a href="{{ block.settings.link_2 }}" class="hc-card__link hc-card__link--secondary">
                {{ block.settings.link_2_label | escape }}
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M4.5 2l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>
            {%- endif -%}
          </div>
        </div>

        <div class="hc-card__media">
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 1600 | image_tag:
              loading: 'lazy',
              widths: '400, 600, 800, 1100, 1400, 1600',
              sizes: '(max-width: 749px) 100vw, (max-width: 989px) 100vw, 50vw',
              class: 'hc-card__img',
              alt: block.settings.image.alt | default: block.settings.heading
            }}
          {%- else -%}
            {{ 'lifestyle-1' | placeholder_svg_tag: 'hc-card__img hc-card__img--placeholder' }}
          {%- endif -%}
        </div>
      </article>
    {%- endfor -%}
  </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "Tarjetas inicio (Apple)",
  "tag": "section",
  "class": "section-home-cards",
  "settings": [],
  "blocks": [
