<div class="cn-section section-{{ section.id }}" id="cn-{{ section.id }}">
  <div class="page-width">
    <div class="cn-scroll-wrap">
      <button class="cn-paddle cn-paddle--prev" aria-label="Anterior" data-cn-prev disabled>
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><polyline points="12 2 5 9 12 16" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>

      <div class="cn-scroll" data-cn-scroll>
        <ul class="cn-list">
          {%- for block in section.blocks -%}
            <li class="cn-item" {{ block.shopify_attributes }}>
              <a href="{{ block.settings.link }}" class="cn-link">
                <div class="cn-img-wrap">
                  {%- if block.settings.image != blank -%}
                    {{ block.settings.image | image_url: width: 120 | image_tag:
                      loading: 'lazy',
                      class: 'cn-img'
                    }}
                  {%- else -%}
                    {{ 'collection-1' | placeholder_svg_tag: 'cn-img cn-img--placeholder' }}
                  {%- endif -%}
                </div>
                <span class="cn-label">{{ block.settings.label }}</span>
                {%- if block.settings.show_badge -%}
                  <span class="cn-badge" style="color: {{ block.settings.badge_color }};">
                    {{ block.settings.badge_text }}
                  </span>
                {%- endif -%}
              </a>
            </li>
          {%- endfor -%}
        </ul>
      </div>

      <button class="cn-paddle cn-paddle--next" aria-label="Siguiente" data-cn-next>
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><polyline points="6 2 13 9 6 16" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>
  </div>
</div>

<script>
(function(){
  var w = document.getElementById('cn-{{ section.id }}');
  if(!w) return;
  var s = w.querySelector('[data-cn-scroll]');
  var prev = w.querySelector('[data-cn-prev]');
  var next = w.querySelector('[data-cn-next]');
  function sync(){
    prev.disabled = s.scrollLeft <= 2;
    next.disabled = s.scrollLeft + s.offsetWidth >= s.scrollWidth - 2;
  }
  prev.addEventListener('click', function(){ s.scrollBy({left: -200, behavior:'smooth'}); });
  next.addEventListener('click', function(){ s.scrollBy({left: 200, behavior:'smooth'}); });
  s.addEventListener('scroll', sync);
  sync();
})();
</script>

{% schema %}
{
  "name": "Navegación categorías",
  "tag": "section",
  "class": "section-category-nav",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Color de fondo",
      "default": "#f5f5f7"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Categoría",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagen"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Nombre",
          "default": "iPhone 17 Pro"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Enlace"
        },
        {
          "type": "checkbox",
          "id": "show_badge",
          "label": "Mostrar badge",
          "default": false
        },
        {
          "type": "text",
          "id": "badge_text",
          "label": "Texto del badge",
          "default": "Nuevo"
        },
        {
          "type": "color",
          "id": "badge_color",
          "label": "Color del badge",
          "default": "#FF9500"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Navegación categorías",
      "blocks": [
        { "type": "category", "settings": { "label": "iPhone 17 Pro" } },
        { "type": "category", "settings": { "label": "iPhone Air" } },
        { "type": "category", "settings": { "label": "iPhone 17" } },
        { "type": "category", "settings": { "label": "iPhone 17e", "show_badge": true } },
        { "type": "category", "settings": { "label": "iPhone 16" } },
        { "type": "category", "settings": { "label": "Comparar" } }
      ]
    }
  ]
}
{% endschema %}
