{%- assign pf_collection = collections[section.settings.collection] -%}
{%- assign pf_limit = section.settings.products_to_show -%}
{%- if pf_collection != blank and pf_collection.products.size > 0 -%}
<section class="pf-section section-{{ section.id }}" id="section-{{ section.id }}">
  <div class="page-width">

    <header class="pf-section__header">
      {%- if section.settings.title != blank -%}
        <h2 class="pf-section__title">{{ section.settings.title }}</h2>
      {%- endif -%}
      {%- if section.settings.compare_link != blank and section.settings.compare_label != blank -%}
        <div class="pf-section__cta">
          <a href="{{ section.settings.compare_link }}" class="pf-section__compare-link">
            {{ section.settings.compare_label }} <span aria-hidden="true">&rsaquo;</span>
          </a>
        </div>
      {%- endif -%}
    </header>

    <div class="pf-gallery">
      <ul class="pf-gallery__list" role="list">
        {%- for product in pf_collection.products limit: pf_limit -%}
          <li class="pf-tile" role="listitem">

            <a href="{{ product.url }}" class="pf-tile__image-link" aria-label="{{ product.title }}">
              <div class="pf-tile__image-wrap">
                {%- if product.featured_image != blank -%}
                  {{ product.featured_image | image_url: width: 680 | image_tag:
                    loading: 'lazy',
                    widths: '340, 500, 680',
                    class: 'pf-tile__image',
                    alt: product.featured_image.alt | default: product.title
                  }}
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'pf-tile__image' }}
                {%- endif -%}
              </div>
            </a>

            {%- if product.variants.size > 1 -%}
              <div class="pf-tile__swatches" role="list" aria-label="Variantes disponibles">
                {%- for variant in product.variants limit: 5 -%}
                  {%- if variant.option1 != blank -%}
                    <span class="pf-tile__swatch pf-tile__swatch--img" role="listitem" title="{{ variant.option1 }}">
                      {%- if variant.image != blank -%}
                        {{ variant.image | image_url: width: 24 | image_tag: class: 'pf-tile__swatch-img', alt: variant.option1 }}
                      {%- else -%}
                        <span class="pf-tile__swatch-dot"></span>
                      {%- endif -%}
                    </span>
                  {%- endif -%}
                {%- endfor -%}
              </div>
            {%- endif -%}

            <h3 class="pf-tile__name">{{ product.title }}</h3>

            {%- if product.description != blank -%}
              <p class="pf-tile__desc">{{ product.description | strip_html | truncate: 100 }}</p>
            {%- endif -%}

            <div class="pf-tile__ctas">
              <button type="button" class="pf-tile__btn-learn" data-pf-open="{{ product.id }}">
                {{ section.settings.button_label }}
              </button>
            </div>

          </li>
        {%- endfor -%}
      </ul>
    </div>

  </div>

  {%- comment -%} ── Modal de producto ── {%- endcomment -%}
  <div class="fg-modal" id="pf-modal-{{ section.id }}" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Información del producto">
    <div class="fg-modal__overlay" data-pf-close></div>
    <div class="fg-modal__dialog">
      <button class="fg-modal__close" type="button" data-pf-close aria-label="Cerrar">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M1 1l14 14M15 1L1 15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </button>
      <div class="fg-modal__body">
        {%- for product in pf_collection.products limit: pf_limit -%}
          <div class="fg-modal__content" id="pf-modal-content-{{ product.id }}" hidden>
            <h2 class="fg-modal__heading">{{ product.title | escape }}</h2>
            {%- if product.images.size > 0 -%}
              <div class="fg-modal__images">
                {%- for img in product.images limit: 3 -%}
                  {{ img | image_url: width: 900 | image_tag: loading: 'lazy', class: 'fg-modal__img', alt: img.alt | default: product.title }}
                {%- endfor -%}
              </div>
            {%- endif -%}
            {%- if product.description != blank -%}
              <div class="fg-modal__text rte">{{ product.description }}</div>
            {%- endif -%}
            <a href="{{ product.url }}" class="btn fg-modal__cta">Ver producto</a>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>

  <script>
  (function() {
    var sId = '{{ section.id }}';
    var sectionEl = document.getElementById('section-' + sId);
    var modal = document.getElementById('pf-modal-' + sId);
    if (!sectionEl || !modal) return;

    function openModal(productId) {
      modal.querySelectorAll('.fg-modal__content').forEach(function(c) { c.hidden = true; });
      var content = document.getElementById('pf-modal-content-' + productId);
      if (content) content.hidden = false;
      modal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      modal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    sectionEl.querySelectorAll('[data-pf-open]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        openModal(this.getAttribute('data-pf-open'));
      });
    });

    modal.querySelectorAll('[data-pf-close]').forEach(function(el) {
      el.addEventListener('click', closeModal);
    });

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && modal.getAttribute('aria-hidden') === 'false') closeModal();
    });
  })();
  </script>

</section>
{%- endif -%}

{% schema %}
{
  "name": "Familia de productos",
  "tag": "section",
  "class": "section-product-family",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Lo más destacado."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Colección"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4,
      "label": "Productos a mostrar"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Texto botón",
      "default": "Más información"
    },
    {
      "type": "text",
      "id": "compare_label",
      "label": "Texto del enlace comparar",
      "default": "Comparar todos los modelos"
    },
    {
      "type": "url",
      "id": "compare_link",
      "label": "Enlace comparar"
    }
  ],
  "presets": [
    {
      "name": "Familia de productos"
    }
  ]
}
{% endschema %}
