{%- if section.blocks.size > 0 -%}
<section class="pf-section section-{{ section.id }}" id="section-{{ section.id }}">
  <div class="page-width">

    <header class="pf-section__header">
      {%- if section.settings.title != blank -%}
        <h2 class="pf-section__title">{{ section.settings.title }}</h2>
      {%- endif -%}
    </header>

    <div class="pf-gallery">
      <ul class="pf-gallery__list pf-gallery__list--{{ section.settings.card_shape }}" role="list">
        {%- for block in section.blocks -%}
          {%- assign pf_product = block.settings.product -%}
          <li class="pf-tile" role="listitem" {{ block.shopify_attributes }}>

            {%- if pf_product != blank -%}
              <a href="{{ pf_product.url }}" class="pf-tile__image-link" aria-label="{{ pf_product.title }}">
            {%- else -%}
              <div class="pf-tile__image-link">
            {%- endif -%}
              <div class="pf-tile__image-wrap">
                {%- if block.settings.card_image != blank -%}
                  {{ block.settings.card_image | image_url: width: 680 | image_tag:
                    loading: 'lazy',
                    widths: '340, 500, 680',
                    sizes: '(max-width: 749px) 100vw, (max-width: 989px) 50vw, 25vw',
                    class: 'pf-tile__image',
                    alt: block.settings.card_image.alt | default: block.settings.card_title
                  }}
                {%- elsif pf_product != blank and pf_product.featured_image != blank -%}
                  {{ pf_product.featured_image | image_url: width: 680 | image_tag:
                    loading: 'lazy',
                    widths: '340, 500, 680',
                    sizes: '(max-width: 749px) 100vw, (max-width: 989px) 50vw, 25vw',
                    class: 'pf-tile__image',
                    alt: pf_product.featured_image.alt | default: pf_product.title
                  }}
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'pf-tile__image' }}
                {%- endif -%}
              </div>
            {%- if pf_product != blank -%}
              </a>
            {%- else -%}
              </div>
            {%- endif -%}

            <h3 class="pf-tile__name">
              {%- if block.settings.card_title != blank -%}
                {{ block.settings.card_title | escape }}
              {%- elsif pf_product != blank -%}
                {{ pf_product.title }}
              {%- endif -%}
            </h3>

            {%- assign pf_desc = block.settings.card_description -%}
            {%- if pf_desc == blank and pf_product != blank -%}
              {%- assign pf_desc = pf_product.description | strip_html | truncate: 100 -%}
            {%- endif -%}
            {%- if pf_desc != blank -%}
              <p class="pf-tile__desc">{{ pf_desc }}</p>
            {%- endif -%}

            <div class="pf-tile__ctas">
              <button type="button" class="pf-tile__btn-learn" data-pf-open="{{ block.id }}">
                {{ section.settings.button_label }}
              </button>
            </div>

          </li>
        {%- endfor -%}
      </ul>
    </div>

    {%- if section.settings.compare_link != blank and section.settings.compare_label != blank -%}
      <div class="pf-section__compare-wrap">
        <a href="{{ section.settings.compare_link }}" class="pf-section__compare-btn">
          {{ section.settings.compare_label }}
        </a>
      </div>
    {%- endif -%}

  </div>

  {%- comment -%} ── Modal por bloque ── {%- endcomment -%}
  <div class="fg-modal" id="pf-modal-{{ section.id }}" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Información del producto">
    <div class="fg-modal__overlay" data-pf-close></div>
    <div class="fg-modal__dialog">
      <button class="fg-modal__close" type="button" data-pf-close aria-label="Cerrar">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M1 1l14 14M15 1L1 15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </button>
      <div class="fg-modal__body">
        {%- for block in section.blocks -%}
          {%- assign pf_product = block.settings.product -%}
          <div class="fg-modal__content" id="pf-modal-content-{{ block.id }}" hidden>

            {%- if block.settings.modal_heading != blank -%}
              <h2 class="fg-modal__heading">{{ block.settings.modal_heading | escape }}</h2>
            {%- endif -%}

            {%- comment -%} Grupo 1 {%- endcomment -%}
            {%- if block.settings.modal_title_1 != blank or block.settings.modal_desc_1 != blank or block.settings.modal_img_1 != blank -%}
              <div class="pf-modal__group">
                {%- if block.settings.modal_title_1 != blank -%}
                  <h3 class="pf-modal__group-title">{{ block.settings.modal_title_1 | escape }}</h3>
                {%- endif -%}
                {%- if block.settings.modal_desc_1 != blank -%}
                  <div class="pf-modal__group-desc rte">{{ block.settings.modal_desc_1 }}</div>
                {%- endif -%}
                {%- if block.settings.modal_img_1 != blank -%}
                  <div class="pf-modal__group-img-wrap">
                    {{ block.settings.modal_img_1 | image_url: width: 900 | image_tag: loading: 'lazy', class: 'pf-modal__group-img', alt: block.settings.modal_img_1.alt | default: block.settings.modal_title_1 }}
                  </div>
                {%- endif -%}
              </div>
            {%- endif -%}

            {%- comment -%} Grupo 2 {%- endcomment -%}
            {%- if block.settings.modal_title_2 != blank or block.settings.modal_desc_2 != blank or block.settings.modal_img_2 != blank -%}
              <div class="pf-modal__group">
                {%- if block.settings.modal_title_2 != blank -%}
                  <h3 class="pf-modal__group-title">{{ block.settings.modal_title_2 | escape }}</h3>
                {%- endif -%}
                {%- if block.settings.modal_desc_2 != blank -%}
                  <div class="pf-modal__group-desc rte">{{ block.settings.modal_desc_2 }}</div>
                {%- endif -%}
                {%- if block.settings.modal_img_2 != blank -%}
                  <div class="pf-modal__group-img-wrap">
                    {{ block.settings.modal_img_2 | image_url: width: 900 | image_tag: loading: 'lazy', class: 'pf-modal__group-img', alt: block.settings.modal_img_2.alt | default: block.settings.modal_title_2 }}
                  </div>
                {%- endif -%}
              </div>
            {%- endif -%}

            {%- comment -%} Grupo 3 {%- endcomment -%}
            {%- if block.settings.modal_title_3 != blank or block.settings.modal_desc_3 != blank or block.settings.modal_img_3 != blank -%}
              <div class="pf-modal__group">
                {%- if block.settings.modal_title_3 != blank -%}
                  <h3 class="pf-modal__group-title">{{ block.settings.modal_title_3 | escape }}</h3>
                {%- endif -%}
                {%- if block.settings.modal_desc_3 != blank -%}
                  <div class="pf-modal__group-desc rte">{{ block.settings.modal_desc_3 }}</div>
                {%- endif -%}
                {%- if block.settings.modal_img_3 != blank -%}
                  <div class="pf-modal__group-img-wrap">
                    {{ block.settings.modal_img_3 | image_url: width: 900 | image_tag: loading: 'lazy', class: 'pf-modal__group-img', alt: block.settings.modal_img_3.alt | default: block.settings.modal_title_3 }}
                  </div>
                {%- endif -%}
              </div>
            {%- endif -%}

            {%- assign modal_link = block.settings.modal_link -%}
            {%- if modal_link == blank and pf_product != blank -%}
              {%- assign modal_link = pf_product.url -%}
            {%- endif -%}
            {%- if modal_link != blank -%}
              <a href="{{ modal_link }}" class="btn fg-modal__cta">
                {{ block.settings.modal_link_label | default: 'Ver producto' | escape }}
              </a>
            {%- endif -%}

          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>

  <script>
  (function() {
    var sId = '{{ section.id }}';
    var sectionEl = document.getElementById('section-' + sId);
    var modal = document.getElementById('pf-modal-' + sId);
    if (!sectionEl || !modal) return;

    function openModal(blockId) {
      modal.querySelectorAll('.fg-modal__content').forEach(function(c) { c.hidden = true; });
      var content = document.getElementById('pf-modal-content-' + blockId);
      if (content) content.hidden = false;
      modal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      modal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    sectionEl.querySelectorAll('[data-pf-open]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        openModal(this.getAttribute('data-pf-open'));
      });
    });

    modal.querySelectorAll('[data-pf-close]').forEach(function(el) {
      el.addEventListener('click', closeModal);
    });

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && modal.getAttribute('aria-hidden') === 'false') closeModal();
    });
  })();
  </script>

</section>
{%- endif -%}

{% schema %}
{
  "name": "Familia de productos",
  "tag": "section",
  "class": "section-product-family",
  "settings": [
    {
      "type": "select",
      "id": "card_shape",
      "label": "Forma de las tarjetas",
      "options": [
        { "value": "portrait", "label": "Rectangular (3:4)" },
        { "value": "square", "label": "Cuadrado (1:1)" },
        { "value": "landscape", "label": "Horizontal (4:3)" }
      ],
      "default": "portrait"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Lo más destacado."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Texto botón 'Más información'",
      "default": "Más información"
    },
    {
      "type": "text",
      "id": "compare_label",
      "label": "Texto del enlace comparar",
      "default": "Comparar todos los modelos"
    },
    {
      "type": "url",
      "id": "compare_link",
      "label": "Enlace comparar"
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Tarjeta de producto",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Producto (opcional)"
        },
        {
          "type": "header",
          "content": "Tarjeta"
        },
        {
          "type": "image_picker",
          "id": "card_image",
          "label": "Imagen de la tarjeta"
        },
        {
          "type": "text",
          "id": "card_title",
          "label": "Título de la tarjeta"
        },
        {
          "type": "text",
          "id": "card_description",
          "label": "Descripción corta (tarjeta)"
        },
        {
          "type": "header",
          "content": "Modal — General"
        },
        {
          "type": "text",
          "id": "modal_heading",
          "label": "Título general del modal",
          "info": "Ej: Innovación"
        },
        {
          "type": "header",
          "content": "Modal — Sección 1"
        },
        {
          "type": "text",
          "id": "modal_title_1",
          "label": "Título sección 1"
        },
        {
          "type": "richtext",
          "id": "modal_desc_1",
          "label": "Descripción sección 1"
        },
        {
          "type": "image_picker",
          "id": "modal_img_1",
          "label": "Imagen sección 1"
        },
        {
          "type": "header",
          "content": "Modal — Sección 2"
        },
        {
          "type": "text",
          "id": "modal_title_2",
          "label": "Título sección 2"
        },
        {
          "type": "richtext",
          "id": "modal_desc_2",
          "label": "Descripción sección 2"
        },
        {
          "type": "image_picker",
          "id": "modal_img_2",
          "label": "Imagen sección 2"
        },
        {
          "type": "header",
          "content": "Modal — Sección 3"
        },
        {
          "type": "text",
          "id": "modal_title_3",
          "label": "Título sección 3"
        },
        {
          "type": "richtext",
          "id": "modal_desc_3",
          "label": "Descripción sección 3"
        },
        {
          "type": "image_picker",
          "id": "modal_img_3",
          "label": "Imagen sección 3"
        },
        {
          "type": "header",
          "content": "Botón del modal"
        },
        {
          "type": "url",
          "id": "modal_link",
          "label": "Enlace del botón (modal)"
        },
        {
          "type": "text",
          "id": "modal_link_label",
          "label": "Texto del botón (modal)",
          "default": "Ver producto"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Familia de productos",
      "blocks": [
        { "type": "product_card" },
        { "type": "product_card" },
        { "type": "product_card" },
        { "type": "product_card" }
      ]
    }
  ]
}
{% endschema %}
