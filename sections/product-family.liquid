{%- if section.blocks.size > 0 -%}
<section class="pf-section section-{{ section.id }}" id="section-{{ section.id }}">
  <div class="page-width">

    <header class="pf-section__header">
      {%- if section.settings.title != blank -%}
        <h2 class="pf-section__title">{{ section.settings.title }}</h2>
      {%- endif -%}
    </header>

    <div class="pf-gallery">
      <ul class="pf-gallery__list pf-gallery__list--{{ section.settings.card_shape }}" role="list">
        {%- for block in section.blocks -%}
          {%- assign pf_product = block.settings.product -%}
          <li class="pf-tile" role="listitem" {{ block.shopify_attributes }}>

            {%- if pf_product != blank -%}
              <a href="{{ pf_product.url }}" class="pf-tile__image-link" aria-label="{{ pf_product.title }}">
            {%- else -%}
              <div class="pf-tile__image-link">
            {%- endif -%}
              <div class="pf-tile__image-wrap">
                {%- if block.settings.card_image != blank -%}
                  {{ block.settings.card_image | image_url: width: 680 | image_tag:
                    loading: 'lazy',
                    widths: '340, 500, 680',
                    sizes: '(max-width: 749px) 100vw, (max-width: 989px) 50vw, 25vw',
                    class: 'pf-tile__image',
                    alt: block.settings.card_image.alt | default: block.settings.card_title
                  }}
                {%- elsif pf_product != blank and pf_product.featured_image != blank -%}
                  {{ pf_product.featured_image | image_url: width: 680 | image_tag:
                    loading: 'lazy',
                    widths: '340, 500, 680',
                    sizes: '(max-width: 749px) 100vw, (max-width: 989px) 50vw, 25vw',
                    class: 'pf-tile__image',
                    alt: pf_product.featured_image.alt | default: pf_product.title
                  }}
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'pf-tile__image' }}
                {%- endif -%}
              </div>
            {%- if pf_product != blank -%}
              </a>
            {%- else -%}
              </div>
            {%- endif -%}

            <h3 class="pf-tile__name">
              {%- if block.settings.card_title != blank -%}
                {{ block.settings.card_title | escape }}
              {%- elsif pf_product != blank -%}
                {{ pf_product.title }}
              {%- endif -%}
            </h3>

            {%- assign pf_desc = block.settings.card_description -%}
            {%- if pf_desc == blank and pf_product != blank -%}
              {%- assign pf_desc = pf_product.description | strip_html | truncate: 100 -%}
            {%- endif -%}
            {%- if pf_desc != blank -%}
              <p class="pf-tile__desc">{{ pf_desc }}</p>
            {%- endif -%}

            {%- assign pf_product_name = '' -%}
            {%- if block.settings.card_title != blank -%}
              {%- assign pf_product_name = block.settings.card_title -%}
            {%- elsif pf_product != blank -%}
              {%- assign pf_product_name = pf_product.title -%}
            {%- endif -%}

            <div class="pf-tile__ctas">
              {%- if block.settings.info_page_link != blank -%}
                <a href="{{ block.settings.info_page_link }}" class="pf-tile__btn-learn">
                  {{ section.settings.button_label }}
                </a>
              {%- else -%}
                <span class="pf-tile__btn-learn pf-tile__btn-learn--no-link">{{ section.settings.button_label }}</span>
              {%- endif -%}
              {%- if section.settings.whatsapp_number != blank -%}
                <button type="button" class="pf-tile__btn-buy" data-pf-quote
                  data-product-name="{{ pf_product_name | escape }}">
                  {{ section.settings.quote_label | default: 'Cotizar' }}
                </button>
              {%- endif -%}
            </div>

          </li>
        {%- endfor -%}
      </ul>
    </div>

    {%- if section.settings.compare_link != blank and section.settings.compare_label != blank -%}
      <div class="pf-section__compare-wrap">
        <a href="{{ section.settings.compare_link }}" class="pf-section__compare-btn">
          {{ section.settings.compare_label }}
        </a>
      </div>
    {%- endif -%}

  </div>

  {%- comment -%} ── Modal de cotización ── {%- endcomment -%}
  <div class="fg-modal pf-quote-modal" id="pf-quote-modal-{{ section.id }}" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="pf-quote-title-{{ section.id }}">
    <div class="fg-modal__overlay" data-pf-quote-close></div>
    <div class="fg-modal__dialog">
      <button class="fg-modal__close" type="button" data-pf-quote-close aria-label="Cerrar">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M1 1l14 14M15 1L1 15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </button>

      <p class="pf-quote__product-label">Solicitando información sobre:</p>
      <p class="pf-quote__product-name" id="pf-quote-product-{{ section.id }}"></p>

      <h2 class="fg-modal__heading" id="pf-quote-title-{{ section.id }}">Ingrese sus datos para evaluarlo</h2>

      <form class="pf-quote__form" id="pf-quote-form-{{ section.id }}" novalidate>
        <div class="ct-form__field">
          <label class="ct-form__label" for="pf-quote-name-{{ section.id }}">Nombre completo</label>
          <input class="ct-form__input" type="text" id="pf-quote-name-{{ section.id }}" name="name" required placeholder="Ej: Juan Pérez">
        </div>
        <div class="ct-form__field">
          <label class="ct-form__label" for="pf-quote-dni-{{ section.id }}">DNI</label>
          <input class="ct-form__input" type="text" id="pf-quote-dni-{{ section.id }}" name="dni" required placeholder="Ej: 12345678" pattern="[0-9]{6,12}" inputmode="numeric">
        </div>
        <div class="ct-form__field">
          <label class="ct-form__label" for="pf-quote-email-{{ section.id }}">Correo electrónico</label>
          <input class="ct-form__input" type="email" id="pf-quote-email-{{ section.id }}" name="email" required placeholder="Ej: juan@correo.com">
        </div>
        <div class="ct-form__actions">
          <button type="submit" class="pf-quote__submit">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.122.553 4.112 1.524 5.842L.057 23.457a.75.75 0 0 0 .921.921l5.618-1.467A11.945 11.945 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.9 0-3.678-.493-5.22-1.357l-.374-.213-3.882 1.014 1.015-3.72-.235-.385A9.944 9.944 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
            Enviar por WhatsApp
          </button>
        </div>
      </form>
    </div>
  </div>

  <script>
  (function() {
    var sId = '{{ section.id }}';
    var waNumber = '{{ section.settings.whatsapp_number | strip | remove: '+' | remove: '-' | remove: ' ' }}';
    var sectionEl = document.getElementById('section-' + sId);
    var modal = document.getElementById('pf-quote-modal-' + sId);
    var productLabel = document.getElementById('pf-quote-product-' + sId);
    var form = document.getElementById('pf-quote-form-' + sId);
    if (!sectionEl || !modal) return;

    function openModal(productName) {
      if (productLabel) productLabel.textContent = productName;
      modal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      var firstInput = form && form.querySelector('input');
      if (firstInput) setTimeout(function() { firstInput.focus(); }, 50);
    }

    function closeModal() {
      modal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      if (form) form.reset();
    }

    sectionEl.querySelectorAll('[data-pf-quote]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        openModal(this.getAttribute('data-product-name') || '');
      });
    });

    modal.querySelectorAll('[data-pf-quote-close]').forEach(function(el) {
      el.addEventListener('click', closeModal);
    });

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && modal.getAttribute('aria-hidden') === 'false') closeModal();
    });

    if (form) {
      form.addEventListener('submit', function(e) {
        e.preventDefault();
        var name = form.querySelector('[name="name"]').value.trim();
        var dni = form.querySelector('[name="dni"]').value.trim();
        var email = form.querySelector('[name="email"]').value.trim();
        var product = productLabel ? productLabel.textContent : '';
        if (!name || !dni || !email) return;
        var msg = '\u00a1Hola! Quisiera informaci\u00f3n sobre: *' + product + '*\n\n'
          + '\ud83d\udccb *Mis datos:*\n'
          + '\u2022 Nombre: ' + name + '\n'
          + '\u2022 DNI: ' + dni + '\n'
          + '\u2022 Correo: ' + email;
        var url = 'https://wa.me/' + waNumber + '?text=' + encodeURIComponent(msg);
        window.open(url, '_blank', 'noopener,noreferrer');
        closeModal();
      });
    }
  })();
  </script>

</section>
{%- endif -%}

{% schema %}
{
  "name": "Familia de productos",
  "tag": "section",
  "class": "section-product-family",
  "settings": [
    {
      "type": "text",
      "id": "whatsapp_number",
      "label": "Número de WhatsApp",
      "info": "Incluye el código de país sin +. Ej: 5491122334455"
    },
    {      "type": "text",
      "id": "quote_label",
      "label": "Texto del bot\u00f3n cotizar",
      "default": "Cotizar"
    },
    {      "type": "select",
      "id": "card_shape",
      "label": "Forma de las tarjetas",
      "options": [
        { "value": "portrait", "label": "Rectangular (3:4)" },
        { "value": "square", "label": "Cuadrado (1:1)" },
        { "value": "landscape", "label": "Horizontal (4:3)" }
      ],
      "default": "portrait"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Lo más destacado."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Texto botón 'Más información'",
      "default": "Más información"
    },
    {
      "type": "text",
      "id": "compare_label",
      "label": "Texto del enlace comparar",
      "default": "Comparar todos los modelos"
    },
    {
      "type": "url",
      "id": "compare_link",
      "label": "Enlace comparar"
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Tarjeta de producto",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Producto (opcional)"
        },
        {
          "type": "header",
          "content": "Tarjeta"
        },
        {
          "type": "image_picker",
          "id": "card_image",
          "label": "Imagen de la tarjeta"
        },
        {
          "type": "text",
          "id": "card_title",
          "label": "Título de la tarjeta"
        },
        {
          "type": "text",
          "id": "card_description",
          "label": "Descripción corta (tarjeta)"
        },
        {          "type": "url",
          "id": "info_page_link",
          "label": "Enlace 'M\u00e1s informaci\u00f3n'",
          "info": "Apunta a la p\u00e1gina informativa del producto (template page.product-info)"
        },
        {          "type": "header",
          "content": "Modal — General"
        },
        {
          "type": "text",
          "id": "modal_heading",
          "label": "Título general del modal",
          "info": "Ej: Innovación"
        },
        {
          "type": "header",
          "content": "Modal — Sección 1"
        },
        {
          "type": "text",
          "id": "modal_title_1",
          "label": "Título sección 1"
        },
        {
          "type": "richtext",
          "id": "modal_desc_1",
          "label": "Descripción sección 1"
        },
        {
          "type": "image_picker",
          "id": "modal_img_1",
          "label": "Imagen sección 1"
        },
        {
          "type": "header",
          "content": "Modal — Sección 2"
        },
        {
          "type": "text",
          "id": "modal_title_2",
          "label": "Título sección 2"
        },
        {
          "type": "richtext",
          "id": "modal_desc_2",
          "label": "Descripción sección 2"
        },
        {
          "type": "image_picker",
          "id": "modal_img_2",
          "label": "Imagen sección 2"
        },
        {
          "type": "header",
          "content": "Modal — Sección 3"
        },
        {
          "type": "text",
          "id": "modal_title_3",
          "label": "Título sección 3"
        },
        {
          "type": "richtext",
          "id": "modal_desc_3",
          "label": "Descripción sección 3"
        },
        {
          "type": "image_picker",
          "id": "modal_img_3",
          "label": "Imagen sección 3"
        },
        {
          "type": "header",
          "content": "Botón del modal"
        },
        {
          "type": "url",
          "id": "modal_link",
          "label": "Enlace del botón (modal)"
        },
        {
          "type": "text",
          "id": "modal_link_label",
          "label": "Texto del botón (modal)",
          "default": "Ver producto"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Familia de productos",
      "blocks": [
        { "type": "product_card" },
        { "type": "product_card" },
        { "type": "product_card" },
        { "type": "product_card" }
      ]
    }
  ]
}
{% endschema %}
