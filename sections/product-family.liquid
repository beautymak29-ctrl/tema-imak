{%- if section.blocks.size > 0 -%}
<section class="product-family section-{{ section.id }}" id="section-{{ section.id }}">
  <div class="page-width">

    <div class="product-family__header">
      {%- if section.settings.title != blank -%}
        <h2 class="product-family__title">{{ section.settings.title }}</h2>
      {%- endif -%}
      {%- if section.settings.compare_link != blank and section.settings.compare_label != blank -%}
        <a href="{{ section.settings.compare_link }}" class="product-family__compare-link">
          {{ section.settings.compare_label }} &rsaquo;
        </a>
      {%- endif -%}
    </div>

    <div class="product-family__grid product-family__grid--{{ section.blocks.size }}">
      {%- for block in section.blocks -%}
        <div class="product-family__card" {{ block.shopify_attributes }}>

          <a href="{{ block.settings.link }}" class="product-family__card-image-link">
            {%- if block.settings.image != blank -%}
              <div class="product-family__image-wrapper">
                {{ block.settings.image | image_url: width: 600 | image_tag:
                  loading: 'lazy',
                  widths: '300, 400, 600',
                  class: 'product-family__image'
                }}
              </div>
            {%- else -%}
              <div class="product-family__image-wrapper product-family__image-wrapper--placeholder">
                {{ 'product-1' | placeholder_svg_tag: 'product-family__image product-family__image--placeholder' }}
              </div>
            {%- endif -%}
          </a>

          {%- assign swatches = block.settings.swatch_colors | split: ',' -%}
          {%- if swatches.size > 0 and block.settings.swatch_colors != blank -%}
            <div class="product-family__swatches">
              {%- for swatch in swatches -%}
                <span class="product-family__swatch" style="background-color: {{ swatch | strip }};"></span>
              {%- endfor -%}
            </div>
          {%- endif -%}

          <div class="product-family__info">
            {%- if block.settings.badge != blank -%}
              <span class="product-family__badge" style="color: {{ block.settings.badge_color }};">
                {{ block.settings.badge }}
              </span>
            {%- endif -%}
            <h3 class="product-family__name">
              <a href="{{ block.settings.link }}">{{ block.settings.name }}</a>
            </h3>
            {%- if block.settings.description != blank -%}
              <p class="product-family__description">{{ block.settings.description }}</p>
            {%- endif -%}
          </div>

          {%- if block.settings.button_label != blank -%}
            <div class="product-family__actions">
              <a href="{{ block.settings.link }}" class="btn btn--small">
                {{ block.settings.button_label }}
              </a>
            </div>
          {%- endif -%}

        </div>
      {%- endfor -%}
    </div>

  </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "Familia de productos",
  "tag": "section",
  "class": "section-product-family",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Conoce a la familia."
    },
    {
      "type": "text",
      "id": "compare_label",
      "label": "Texto del enlace comparar",
      "default": "Comparar todos los modelos"
    },
    {
      "type": "url",
      "id": "compare_link",
      "label": "Enlace comparar"
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Producto",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagen del producto"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Nombre del producto",
          "default": "iPhone 17 Pro"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Descripción corta",
          "default": "Un diseño innovador para una batería y un rendimiento sin precedentes."
        },
        {
          "type": "text",
          "id": "swatch_colors",
          "label": "Colores (separados por coma)",
          "info": "Ejemplo: #FF6B00, #1C2634, #FFFFFF",
          "default": "#FF6B00, #1C2634, #FFFFFF"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge (ej: Nuevo)",
          "default": ""
        },
        {
          "type": "color",
          "id": "badge_color",
          "label": "Color del badge",
          "default": "#FF9500"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Enlace"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Texto del botón",
          "default": "Comprar"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Familia de productos",
      "blocks": [
        {
          "type": "product_card",
          "settings": {
            "name": "iPhone 17 Pro",
            "description": "Un diseño innovador para una batería y un rendimiento sin precedentes.",
            "swatch_colors": "#FF6B00, #1C2634, #FFFFFF",
            "button_label": "Conocer más"
          }
        },
        {
          "type": "product_card",
          "settings": {
            "name": "iPhone Air",
            "description": "El iPhone más delgado. El poder de un pro.",
            "swatch_colors": "#D4E8F5, #C8C8C8, #1C1C1C",
            "button_label": "Conocer más"
          }
        },
        {
          "type": "product_card",
          "settings": {
            "name": "iPhone 17",
            "description": "Aún más sorprendente. Aún más resistente.",
            "swatch_colors": "#D8C8E8, #8CAF6C, #7CA8C8, #1C1C1C",
            "button_label": "Conocer más"
          }
        },
        {
          "type": "product_card",
          "settings": {
            "name": "iPhone 17e",
            "description": "Trae de todo. Toda una oportunidad.",
            "badge": "Nuevo",
            "swatch_colors": "#F5D0D0, #1C1C1C",
            "button_label": "Conocer más"
          }
        }
      ]
    }
  ]
}
{% endschema %}
