{% comment %} Footer estilo Apple – ft-* {% endcomment %}
<footer class="ft" role="contentinfo">
  {%- comment -%} Notas legales superiores {%- endcomment -%}
  {%- if section.settings.legal_notes != blank -%}
    <div class="ft__notes page-width">
      <div class="ft__notes-text rte">{{ section.settings.legal_notes }}</div>
    </div>
  {%- endif -%}

  {%- comment -%} Columnas de links {%- endcomment -%}
  <div class="ft__columns page-width">
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'link_list' -%}
          <div class="ft__col" {{ block.shopify_attributes }}>
            {%- if block.settings.heading != blank -%}
              <button class="ft__col-toggle" aria-expanded="false">
                <span class="ft__col-heading">{{ block.settings.heading | escape }}</span>
                <svg class="ft__col-chevron" xmlns="http://www.w3.org/2000/svg" width="10" height="6" viewBox="0 0 10 6"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.2" fill="none"/></svg>
              </button>
              <h3 class="ft__col-heading ft__col-heading--desktop">{{ block.settings.heading | escape }}</h3>
            {%- endif -%}
            {%- if block.settings.menu != blank -%}
              <ul class="ft__col-links" role="list">
                {%- for link in linklists[block.settings.menu].links -%}
                  <li><a href="{{ link.url }}" class="ft__link">{{ link.title | escape }}</a></li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>

        {%- when 'text' -%}
          <div class="ft__col" {{ block.shopify_attributes }}>
            {%- if block.settings.heading != blank -%}
              <button class="ft__col-toggle" aria-expanded="false">
                <span class="ft__col-heading">{{ block.settings.heading | escape }}</span>
                <svg class="ft__col-chevron" xmlns="http://www.w3.org/2000/svg" width="10" height="6" viewBox="0 0 10 6"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.2" fill="none"/></svg>
              </button>
              <h3 class="ft__col-heading ft__col-heading--desktop">{{ block.settings.heading | escape }}</h3>
            {%- endif -%}
            {%- if block.settings.subtext != blank -%}
              <div class="ft__col-links ft__col-text rte">{{ block.settings.subtext }}</div>
            {%- endif -%}
          </div>
      {%- endcase -%}
    {%- endfor -%}
  </div>

  {%- comment -%} Bottom bar {%- endcomment -%}
  <div class="ft__bottom page-width">
    <div class="ft__bottom-inner">
      <p class="ft__copyright">Copyright &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. Todos los derechos reservados.</p>
      {%- if section.settings.bottom_menu != blank -%}
        <nav class="ft__bottom-nav" aria-label="Legal">
          <ul class="ft__bottom-list" role="list">
            {%- for link in linklists[section.settings.bottom_menu].links -%}
              <li><a href="{{ link.url }}" class="ft__bottom-link">{{ link.title | escape }}</a></li>
            {%- endfor -%}
          </ul>
        </nav>
      {%- endif -%}
    </div>
  </div>
</footer>

<script>
(function(){
  var toggles = document.querySelectorAll('.ft__col-toggle');
  toggles.forEach(function(btn){
    btn.addEventListener('click', function(){
      var open = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!open));
      var links = btn.parentElement.querySelector('.ft__col-links');
      if (links) links.classList.toggle('ft__col-links--open');
    });
  });
})();
</script>

{% schema %}
{
  "name": "Footer",
  "blocks": [
    {
      "type": "link_list",
      "name": "Menú",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "Comprar e informarte",
          "label": "Encabezado"
        },
        {
          "type": "link_list",
          "id": "menu",
          "default": "footer",
          "label": "Menú"
        }
      ]
    },
    {
      "type": "text",
      "name": "Texto",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "Sobre nosotros",
          "label": "Encabezado"
        },
        {
          "type": "richtext",
          "id": "subtext",
          "default": "<p>Escribe un texto corto sobre tu tienda.</p>",
          "label": "Contenido"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "richtext",
      "id": "legal_notes",
      "label": "Notas legales",
      "default": "<p>◊ Los precios pueden variar. Aplican términos y condiciones.</p>"
    },
    {
      "type": "link_list",
      "id": "bottom_menu",
      "label": "Menú inferior (legal)",
      "info": "Política de privacidad, términos, etc."
    }
  ]
}
{% endschema %}
