<section class="pp-section section-{{ section.id }}">
  <div class="page-width">

    {%- comment -%} CABECERA {%- endcomment -%}
    <header class="pp-header">
      {%- if section.settings.show_vendor and product.vendor != blank -%}
        <p class="pp-header__vendor">{{ product.vendor }}</p>
      {%- endif -%}
      <h1 class="pp-header__title">{{ product.title }}</h1>
      {%- if product.description != blank -%}
        <div class="pp-header__desc rte">{{ product.description }}</div>
      {%- endif -%}
    </header>

    {%- comment -%} VARIANTES {%- endcomment -%}
    {%- if product.variants.size > 0 -%}
      <div class="pp-variants">
        {%- if section.settings.variants_title != blank -%}
          <h2 class="pp-variants__title">{{ section.settings.variants_title | escape }}</h2>
        {%- endif -%}

        <ul class="pp-variants__list" role="list">
          {%- for variant in product.variants -%}
            <li class="pp-var-card">
              <div class="pp-var-card__media">
                {%- if variant.image != blank -%}
                  {{ variant.image | image_url: width: 600 | image_tag:
                    loading: 'lazy',
                    widths: '300, 480, 600',
                    sizes: '(max-width: 749px) 50vw, 25vw',
                    class: 'pp-var-card__img',
                    alt: variant.image.alt | default: variant.title
                  }}
                {%- elsif product.featured_image != blank -%}
                  {{ product.featured_image | image_url: width: 600 | image_tag:
                    loading: 'lazy',
                    widths: '300, 480, 600',
                    sizes: '(max-width: 749px) 50vw, 25vw',
                    class: 'pp-var-card__img',
                    alt: product.title
                  }}
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'pp-var-card__img pp-var-card__img--placeholder' }}
                {%- endif -%}
              </div>
              <div class="pp-var-card__info">
                <p class="pp-var-card__name">{{ variant.title | escape }}</p>
                {%- if variant.price > 0 -%}
                  <p class="pp-var-card__price-label">{{ section.settings.price_label | default: 'Precio desde' | upcase }}</p>
                  <p class="pp-var-card__price">{{ variant.price | money }}</p>
                {%- endif -%}
              </div>
            </li>
          {%- endfor -%}
        </ul>
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Producto principal",
  "tag": "section",
  "class": "section-main-product",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_vendor",
      "default": true,
      "label": "Mostrar marca"
    },
    {
      "type": "text",
      "id": "variants_title",
      "label": "T\u00edtulo de la secci\u00f3n de versiones",
      "default": "Nuestras versiones"
    },
    {
      "type": "text",
      "id": "price_label",
      "label": "Etiqueta de precio",
      "default": "Precio desde"
    }
  ]
}
{% endschema %}
