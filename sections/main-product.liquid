<section class="pp-section section-{{ section.id }}">
  <div class="page-width">

    {%- comment -%} CABECERA {%- endcomment -%}
    <header class="pp-header">
      {%- if section.settings.show_vendor and product.vendor != blank -%}
        <p class="pp-header__vendor">{{ product.vendor }}</p>
      {%- endif -%}
      <h1 class="pp-header__title">{{ product.title }}</h1>
      {%- if product.description != blank -%}
        <div class="pp-header__desc rte">{{ product.description }}</div>
      {%- endif -%}
    </header>

    {%- comment -%} VARIANTES {%- endcomment -%}
    {%- if product.variants.size > 0 -%}
      {%- assign pp_count = product.variants.size -%}
      {%- if pp_count <= 2 -%}
        {%- assign pp_list_mod = 'pp-variants__list--xl' -%}
      {%- elsif pp_count <= 4 -%}
        {%- assign pp_list_mod = 'pp-variants__list--lg' -%}
      {%- elsif pp_count <= 6 -%}
        {%- assign pp_list_mod = 'pp-variants__list--md' -%}
      {%- else -%}
        {%- assign pp_list_mod = 'pp-variants__list--sm' -%}
      {%- endif -%}
      <div class="pp-variants">
        {%- if section.settings.variants_title != blank -%}
          <h2 class="pp-variants__title">{{ section.settings.variants_title | escape }}</h2>
        {%- endif -%}

        <ul class="pp-variants__list {{ pp_list_mod }}" role="list">
          {%- for variant in product.variants -%}
            <li class="pp-var-card">
              <div class="pp-var-card__media">
                {%- if variant.image != blank -%}
                  {{ variant.image | image_url: width: 600 | image_tag:
                    loading: 'lazy',
                    widths: '300, 480, 600',
                    sizes: '(max-width: 749px) 50vw, 25vw',
                    class: 'pp-var-card__img',
                    alt: variant.image.alt | default: variant.title
                  }}
                {%- elsif product.featured_image != blank -%}
                  {{ product.featured_image | image_url: width: 600 | image_tag:
                    loading: 'lazy',
                    widths: '300, 480, 600',
                    sizes: '(max-width: 749px) 50vw, 25vw',
                    class: 'pp-var-card__img',
                    alt: product.title
                  }}
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'pp-var-card__img pp-var-card__img--placeholder' }}
                {%- endif -%}
              </div>
              <div class="pp-var-card__info">
                <p class="pp-var-card__name">{{ variant.title | escape }}</p>
                {%- if variant.price > 0 -%}
                  <p class="pp-var-card__price-label">{{ section.settings.price_label | default: 'Precio desde' | upcase }}</p>
                  <p class="pp-var-card__price">{{ variant.price | money }}</p>
                {%- endif -%}
              </div>
            </li>
          {%- endfor -%}
        </ul>
      </div>
    {%- endif -%}

    {%- comment -%} BLOQUES PERSONALIZADOS (imagen + descripción) {%- endcomment -%}
    {%- if section.blocks.size > 0 -%}
      <div class="pp-features">
        {%- for block in section.blocks -%}
          {%- case block.type -%}

            {%- when 'feature' -%}
              <div class="pp-feature{% if block.settings.reverse %} pp-feature--reverse{% endif %}" {{ block.shopify_attributes }}>
                {%- if block.settings.image != blank -%}
                  <div class="pp-feature__media">
                    {{ block.settings.image | image_url: width: 900 | image_tag:
                      loading: 'lazy',
                      widths: '400, 600, 900',
                      sizes: '(max-width: 749px) 100vw, 50vw',
                      class: 'pp-feature__img',
                      alt: block.settings.image.alt | default: block.settings.heading
                    }}
                  </div>
                {%- endif -%}
                <div class="pp-feature__body">
                  {%- if block.settings.heading != blank -%}
                    <h2 class="pp-feature__heading">{{ block.settings.heading }}</h2>
                  {%- endif -%}
                  {%- if block.settings.text != blank -%}
                    <div class="pp-feature__text rte">{{ block.settings.text }}</div>
                  {%- endif -%}
                </div>
              </div>

            {%- when 'image_full' -%}
              <div class="pp-feature pp-feature--full" {{ block.shopify_attributes }}>
                {%- if block.settings.image != blank -%}
                  {{ block.settings.image | image_url: width: 1400 | image_tag:
                    loading: 'lazy',
                    widths: '600, 900, 1200, 1400',
                    sizes: '100vw',
                    class: 'pp-feature__img-full',
                    alt: block.settings.image.alt | default: ''
                  }}
                {%- endif -%}
                {%- if block.settings.caption != blank -%}
                  <p class="pp-feature__caption">{{ block.settings.caption }}</p>
                {%- endif -%}
              </div>

          {%- endcase -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Producto principal",
  "tag": "section",
  "class": "section-main-product",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_vendor",
      "default": true,
      "label": "Mostrar marca"
    },
    {
      "type": "text",
      "id": "variants_title",
      "label": "T\u00edtulo de la secci\u00f3n de versiones",
      "default": "Nuestras versiones"
    },
    {
      "type": "text",
      "id": "price_label",
      "label": "Etiqueta de precio",
      "default": "Precio desde"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Imagen + descripci\u00f3n",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Imagen" },
        { "type": "text",         "id": "heading", "label": "T\u00edtulo" },
        { "type": "richtext",     "id": "text",    "label": "Descripci\u00f3n" },
        {
          "type": "checkbox",
          "id": "reverse",
          "label": "Invertir orden (texto a la izquierda)",
          "default": false
        }
      ]
    },
    {
      "type": "image_full",
      "name": "Imagen completa",
      "settings": [
        { "type": "image_picker", "id": "image",   "label": "Imagen" },
        { "type": "text",         "id": "caption", "label": "Pie de imagen (opcional)" }
      ]
    }
  ],
  "presets": [
    { "name": "Producto principal" }
  ]
}
{% endschema %}
