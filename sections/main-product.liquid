<section class="pp-section section-{{ section.id }}">
  <div class="page-width">
    <div class="pp-grid">

      {%- comment -%} MEDIA {%- endcomment -%}
      <div class="pp-media">
        <div class="pp-media__viewer">
          {%- if product.featured_media -%}
            <img
              id="pp-main-img-{{ section.id }}"
              src="{{ product.featured_media | image_url: width: 1000 }}"
              alt="{{ product.featured_media.alt | escape }}"
              width="1000"
              loading="eager"
              fetchpriority="high"
              class="pp-media__img"
            >
          {%- else -%}
            {{ 'product-1' | placeholder_svg_tag: 'pp-media__img pp-media__img--placeholder' }}
          {%- endif -%}
        </div>

        {%- if product.media.size > 1 -%}
          <div class="pp-media__strip" role="list" aria-label="Miniaturas">
            {%- for media in product.media -%}
              <button
                type="button"
                class="pp-thumb{% if forloop.first %} pp-thumb--active{% endif %}"
                data-pp-src="{{ media | image_url: width: 1000 }}"
                data-pp-alt="{{ media.alt | escape }}"
                data-pp-section="{{ section.id }}"
                aria-label="{{ media.alt | default: product.title | escape }}"
              >
                <img
                  src="{{ media | image_url: width: 160 }}"
                  alt="{{ media.alt | escape }}"
                  width="80" height="80"
                  loading="lazy"
                  class="pp-thumb__img"
                >
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} INFO {%- endcomment -%}
      <div class="pp-info">
        {%- if section.settings.show_vendor and product.vendor != blank -%}
          <p class="pp-info__vendor">{{ product.vendor }}</p>
        {%- endif -%}

        <h1 class="pp-info__title">{{ product.title }}</h1>

        {%- if product.has_only_default_variant == false -%}
          <div class="pp-options">
            {%- for option in product.options_with_values -%}
              {%- assign opt_idx = forloop.index0 -%}
              <div class="pp-opt">
                <span class="pp-opt__label">
                  {{ option.name }}:
                  <strong class="pp-opt__current" data-pp-opt-current>{{ option.selected_value }}</strong>
                </span>
                <div class="pp-opt__values" role="group" aria-label="{{ option.name | escape }}">
                  {%- for value in option.values -%}
                    {%- assign v_img_src = '' -%}
                    {%- assign v_img_alt = '' -%}
                    {%- for variant in product.variants -%}
                      {%- if variant.options[opt_idx] == value and variant.image != blank -%}
                        {%- assign v_img_src = variant.image | image_url: width: 1000 -%}
                        {%- assign v_img_alt = variant.image.alt | default: value | escape -%}
                        {%- break -%}
                      {%- endif -%}
                    {%- endfor -%}
                    <button
                      type="button"
                      class="pp-opt__btn{% if option.selected_value == value %} pp-opt__btn--active{% endif %}"
                      data-pp-opt-idx="{{ opt_idx }}"
                      data-pp-opt-value="{{ value | escape }}"
                      data-pp-section="{{ section.id }}"
                      {%- if v_img_src != '' -%}
                        data-pp-src="{{ v_img_src }}"
                        data-pp-alt="{{ v_img_alt }}"
                      {%- endif -%}
                    >
                      {{ value | escape }}
                    </button>
                  {%- endfor -%}
                </div>
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- if product.description != blank -%}
          <div class="pp-info__desc rte">
            {{ product.description }}
          </div>
        {%- endif -%}

        {%- if section.settings.whatsapp_number != blank -%}
          {%- assign pp_wa_msg = 'Hola, me interesa el producto: ' | append: product.title -%}
          <a
            href="https://wa.me/{{ section.settings.whatsapp_number | escape }}?text={{ pp_wa_msg | url_encode }}"
            class="pp-cta__whatsapp"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            {{ section.settings.whatsapp_label | default: 'Cotizar por WhatsApp' }}
          </a>
        {%- endif -%}

      </div>
    </div>
  </div>
</section>

<script>
(function () {
  var sid     = '{{ section.id }}';
  var section = document.querySelector('.section-' + sid);
  if (!section) return;

  var mainImg = section.querySelector('#pp-main-img-' + sid);
  var thumbs  = section.querySelectorAll('.pp-thumb');
  var optBtns = section.querySelectorAll('.pp-opt__btn');

  function setImg(src, alt) {
    if (!mainImg) return;
    mainImg.src = src;
    mainImg.alt = alt || '';
  }

  thumbs.forEach(function (btn) {
    btn.addEventListener('click', function () {
      thumbs.forEach(function (t) { t.classList.remove('pp-thumb--active'); });
      btn.classList.add('pp-thumb--active');
      setImg(btn.dataset.ppSrc, btn.dataset.ppAlt);
    });
  });

  optBtns.forEach(function (btn) {
    btn.addEventListener('click', function () {
      var idx = btn.dataset.ppOptIdx;
      section.querySelectorAll('.pp-opt__btn[data-pp-opt-idx="' + idx + '"]').forEach(function (b) {
        b.classList.remove('pp-opt__btn--active');
      });
      btn.classList.add('pp-opt__btn--active');
      var cur = btn.closest('.pp-opt').querySelector('[data-pp-opt-current]');
      if (cur) cur.textContent = btn.dataset.ppOptValue;
      if (btn.dataset.ppSrc) {
        setImg(btn.dataset.ppSrc, btn.dataset.ppAlt || '');
        thumbs.forEach(function (t) {
          t.classList.toggle('pp-thumb--active', t.dataset.ppSrc === btn.dataset.ppSrc);
        });
      }
    });
  });
})();
</script>

{% schema %}
{
  "name": "Producto principal",
  "tag": "section",
  "class": "section-main-product",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_vendor",
      "default": true,
      "label": "Mostrar marca"
    },
    {
      "type": "text",
      "id": "whatsapp_number",
      "label": "N\u00famero de WhatsApp",
      "info": "Incluye el c\u00f3digo de pa\u00eds sin +. Ej: 5491122334455"
    },
    {
      "type": "text",
      "id": "whatsapp_label",
      "label": "Texto del bot\u00f3n WhatsApp",
      "default": "Cotizar por WhatsApp"
    }
  ]
}
{% endschema %}
