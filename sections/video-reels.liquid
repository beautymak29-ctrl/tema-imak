<section class="vr-section section-{{ section.id }}">
  <div class="page-width">

    {%- if section.settings.title != blank -%}
      <h2 class="vr-title">{{ section.settings.title }}</h2>
    {%- endif -%}

    <div class="vr-gallery">
      <div class="vr-gallery__scroll">
        <ul class="vr-gallery__list">
          {%- for block in section.blocks -%}
            <li class="vr-card" {{ block.shopify_attributes }}>
              <div class="vr-card__inner">
                {%- if block.settings.video != blank -%}
                  <video
                    class="vr-card__video"
                    src="{{ block.settings.video }}"
                    poster="{{ block.settings.poster | image_url: width: 540 }}"
                    playsinline
                    loop
                    muted
                    preload="metadata"
                  ></video>
                  <button class="vr-card__play" aria-label="Reproducir">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M8 5v14l11-7L8 5z" fill="currentColor"/></svg>
                  </button>
                {%- elsif block.settings.poster != blank -%}
                  <img
                    class="vr-card__img"
                    src="{{ block.settings.poster | image_url: width: 540 }}"
                    alt="{{ block.settings.heading | escape }}"
                    loading="lazy"
                    width="270"
                    height="480"
                  >
                {%- else -%}
                  <div class="vr-card__placeholder">
                    {{ 'image' | placeholder_svg_tag }}
                  </div>
                {%- endif -%}

                {%- if block.settings.heading != blank -%}
                  <div class="vr-card__overlay">
                    <p class="vr-card__heading">{{ block.settings.heading }}</p>
                  </div>
                {%- endif -%}
              </div>
            </li>
          {%- endfor -%}
        </ul>
      </div>

      <button class="vr-arrow vr-arrow--prev" aria-label="Anterior" type="button">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M12.5 15l-5-5 5-5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <button class="vr-arrow vr-arrow--next" aria-label="Siguiente" type="button">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M7.5 5l5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>

  </div>
</section>

<script>
(function(){
  var sec = document.querySelector('.section-{{ section.id }}');
  if (!sec) return;
  var scroll = sec.querySelector('.vr-gallery__scroll');
  var prev = sec.querySelector('.vr-arrow--prev');
  var next = sec.querySelector('.vr-arrow--next');
  var cards = sec.querySelectorAll('.vr-card');
  if (!scroll || cards.length === 0) return;

  function getStep() { return cards[0].offsetWidth + 16; }

  if (prev) prev.addEventListener('click', function() {
    scroll.scrollBy({ left: -getStep(), behavior: 'smooth' });
  });
  if (next) next.addEventListener('click', function() {
    scroll.scrollBy({ left: getStep(), behavior: 'smooth' });
  });

  /* Play / Pause on click */
  sec.querySelectorAll('.vr-card__inner').forEach(function(inner) {
    var video = inner.querySelector('video');
    var btn = inner.querySelector('.vr-card__play');
    if (!video || !btn) return;

    btn.addEventListener('click', function() {
      if (video.paused) {
        video.play();
        btn.classList.add('vr-card__play--hidden');
      } else {
        video.pause();
        btn.classList.remove('vr-card__play--hidden');
      }
    });
    video.addEventListener('click', function() {
      if (!video.paused) {
        video.pause();
        btn.classList.remove('vr-card__play--hidden');
      }
    });
  });
})();
</script>

{% schema %}
{
  "name": "Video Reels",
  "tag": "section",
  "class": "section-video-reels",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": ""
    }
  ],
  "blocks": [
    {
      "type": "video",
      "name": "Video",
      "settings": [
        {
          "type": "text",
          "id": "video",
          "label": "URL del video (MP4)"
        },
        {
          "type": "image_picker",
          "id": "poster",
          "label": "Imagen de portada"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Texto superpuesto"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Video Reels",
      "blocks": [
        { "type": "video" },
        { "type": "video" },
        { "type": "video" }
      ]
    }
  ]
}
{% endschema %}
