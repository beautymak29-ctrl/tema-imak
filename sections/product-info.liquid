{%- if section.blocks.size > 0 or section.settings.title != blank -%}
<section class="pi-section section-{{ section.id }}">
  <div class="page-width">

    {%- if section.settings.title != blank -%}
      <header class="pi-header">
        <h1 class="pi-header__title">{{ section.settings.title }}</h1>
        {%- if section.settings.subtitle != blank -%}
          <p class="pi-header__sub">{{ section.settings.subtitle }}</p>
        {%- endif -%}
      </header>
    {%- endif -%}

    {%- for block in section.blocks -%}

      {%- case block.type -%}

        {%- when 'text' -%}
          <div class="pi-block pi-block--text" {{ block.shopify_attributes }}>
            {%- if block.settings.heading != blank -%}
              <h2 class="pi-block__heading">{{ block.settings.heading }}</h2>
            {%- endif -%}
            {%- if block.settings.content != blank -%}
              <div class="pi-block__rte rte">{{ block.settings.content }}</div>
            {%- endif -%}
          </div>

        {%- when 'image' -%}
          <div class="pi-block pi-block--image" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 1400 | image_tag:
                loading: 'lazy',
                widths: '600, 900, 1200, 1400',
                sizes: '(max-width: 749px) 100vw, 90vw',
                class: 'pi-block__img',
                alt: block.settings.image.alt | default: ''
              }}
            {%- endif -%}
            {%- if block.settings.caption != blank -%}
              <p class="pi-block__caption">{{ block.settings.caption }}</p>
            {%- endif -%}
          </div>

        {%- when 'image_text' -%}
          <div class="pi-block pi-block--image-text{% if block.settings.reverse %} pi-block--reverse{% endif %}" {{ block.shopify_attributes }}>
            <div class="pi-block__col pi-block__col--img">
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 900 | image_tag:
                  loading: 'lazy',
                  widths: '400, 600, 900',
                  sizes: '(max-width: 749px) 100vw, 50vw',
                  class: 'pi-block__img',
                  alt: block.settings.image.alt | default: block.settings.heading
                }}
              {%- else -%}
                <div class="pi-block__img-placeholder"></div>
              {%- endif -%}
            </div>
            <div class="pi-block__col pi-block__col--text">
              {%- if block.settings.heading != blank -%}
                <h2 class="pi-block__heading">{{ block.settings.heading }}</h2>
              {%- endif -%}
              {%- if block.settings.content != blank -%}
                <div class="pi-block__rte rte">{{ block.settings.content }}</div>
              {%- endif -%}
            </div>
          </div>

        {%- when 'video' -%}
          <div class="pi-block pi-block--video" {{ block.shopify_attributes }}>
            {%- if block.settings.heading != blank -%}
              <h2 class="pi-block__heading pi-block__heading--center">{{ block.settings.heading }}</h2>
            {%- endif -%}
            {%- if block.settings.video_url != blank -%}
              <div class="pi-block__video-wrap">
                <iframe
                  src="{{ block.settings.video_url | escape }}"
                  allow="autoplay; encrypted-media; picture-in-picture"
                  allowfullscreen
                  loading="lazy"
                  class="pi-block__iframe"
                  title="{{ block.settings.heading | default: 'Video' | escape }}"
                ></iframe>
              </div>
            {%- endif -%}
            {%- if block.settings.caption != blank -%}
              <p class="pi-block__caption">{{ block.settings.caption }}</p>
            {%- endif -%}
          </div>

        {%- when 'gallery' -%}
          <div class="pi-block pi-block--gallery" {{ block.shopify_attributes }}>
            {%- if block.settings.heading != blank -%}
              <h2 class="pi-block__heading pi-block__heading--center">{{ block.settings.heading }}</h2>
            {%- endif -%}
            <div class="pi-gallery">
              {%- for i in (1..4) -%}
                {%- assign img_key = 'image_' | append: i -%}
                {%- if block.settings[img_key] != blank -%}
                  <div class="pi-gallery__item">
                    {{ block.settings[img_key] | image_url: width: 700 | image_tag:
                      loading: 'lazy',
                      widths: '300, 500, 700',
                      sizes: '(max-width: 749px) 50vw, 25vw',
                      class: 'pi-gallery__img',
                      alt: block.settings[img_key].alt | default: ''
                    }}
                  </div>
                {%- endif -%}
              {%- endfor -%}
            </div>
          </div>

      {%- endcase -%}

    {%- endfor -%}

  </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "Informaci\u00f3n del producto",
  "tag": "section",
  "class": "section-product-info",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "T\u00edtulo principal"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subt\u00edtulo"
    }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "Bloque de texto",
      "settings": [
        { "type": "text", "id": "heading", "label": "T\u00edtulo" },
        { "type": "richtext", "id": "content", "label": "Contenido" }
      ]
    },
    {
      "type": "image",
      "name": "Imagen",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Imagen" },
        { "type": "text", "id": "caption", "label": "Pie de foto (opcional)" }
      ]
    },
    {
      "type": "image_text",
      "name": "Imagen + Texto",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Imagen" },
        { "type": "text", "id": "heading", "label": "T\u00edtulo" },
        { "type": "richtext", "id": "content", "label": "Contenido" },
        { "type": "checkbox", "id": "reverse", "label": "Texto a la izquierda (invertir orden)", "default": false }
      ]
    },
    {
      "type": "video",
      "name": "Video",
      "settings": [
        { "type": "text", "id": "heading", "label": "T\u00edtulo (opcional)" },
        {
          "type": "text",
          "id": "video_url",
          "label": "URL embed del video",
          "info": "YouTube: https://www.youtube.com/embed/ID \u2014 Vimeo: https://player.vimeo.com/video/ID"
        },
        { "type": "text", "id": "caption", "label": "Pie de video (opcional)" }
      ]
    },
    {
      "type": "gallery",
      "name": "Galer\u00eda de im\u00e1genes",
      "settings": [
        { "type": "text", "id": "heading", "label": "T\u00edtulo (opcional)" },
        { "type": "image_picker", "id": "image_1", "label": "Imagen 1" },
        { "type": "image_picker", "id": "image_2", "label": "Imagen 2" },
        { "type": "image_picker", "id": "image_3", "label": "Imagen 3" },
        { "type": "image_picker", "id": "image_4", "label": "Imagen 4" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Informaci\u00f3n del producto",
      "blocks": [
        { "type": "text" },
        { "type": "image_text" },
        { "type": "video" },
        { "type": "gallery" }
      ]
    }
  ]
}
{% endschema %}
