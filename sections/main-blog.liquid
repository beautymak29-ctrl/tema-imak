{% comment %} Listado del blog {% endcomment %}
<div class="blog-page page-width section-padding">
  <h1 class="blog-page__title">{{ blog.title }}</h1>

  {%- if blog.articles_count > 0 -%}
    <ul class="blog-grid blog-grid--{{ section.settings.columns_desktop }}-col list-unstyled" role="list">
      {%- for article in blog.articles -%}
        <li class="blog-grid__item">
          <article class="article-card">
            {%- if article.image -%}
              <a href="{{ article.url }}" class="article-card__media">
                <img
                  src="{{ article.image | image_url: width: 600 }}"
                  alt="{{ article.image.alt | escape }}"
                  width="600"
                  height="{{ 600 | divided_by: article.image.aspect_ratio | ceil }}"
                  loading="lazy"
                  class="article-card__image"
                >
              </a>
            {%- endif -%}

            <div class="article-card__info">
              {%- if section.settings.show_date or section.settings.show_author -%}
                <p class="article-card__meta">
                  {%- if section.settings.show_date -%}
                    <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
                      {{ article.published_at | date: format: 'abbreviated_date' }}
                    </time>
                  {%- endif -%}
                  {%- if section.settings.show_author -%}
                    <span class="article-card__author">{{ article.author }}</span>
                  {%- endif -%}
                </p>
              {%- endif -%}

              <h2 class="article-card__title">
                <a href="{{ article.url }}">{{ article.title }}</a>
              </h2>

              {%- if section.settings.show_excerpt and article.excerpt != blank -%}
                <div class="article-card__excerpt rte">{{ article.excerpt }}</div>
              {%- endif -%}

              <a href="{{ article.url }}" class="article-card__read-more">
                {{ 'blogs.article.read_more' | t }} &rarr;
              </a>
            </div>
          </article>
        </li>
      {%- endfor -%}
    </ul>

    {%- if blog.articles_count > section.settings.articles_per_page -%}
      {%- paginate blog.articles by section.settings.articles_per_page -%}
        <nav class="pagination" role="navigation">
          {%- if paginate.previous -%}
            <a href="{{ paginate.previous.url }}" class="pagination__link">← {{ 'general.pagination.previous' | t }}</a>
          {%- endif -%}
          <span class="pagination__info">{{ paginate.current_page }} / {{ paginate.pages }}</span>
          {%- if paginate.next -%}
            <a href="{{ paginate.next.url }}" class="pagination__link">{{ 'general.pagination.next' | t }} →</a>
          {%- endif -%}
        </nav>
      {%- endpaginate -%}
    {%- endif -%}
  {%- else -%}
    <p class="section-empty">{{ 'blogs.article.no_articles' | t }}</p>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Blog",
  "tag": "section",
  "class": "section-main-blog",
  "settings": [
    {
      "type": "range",
      "id": "articles_per_page",
      "min": 3,
      "max": 24,
      "step": 3,
      "default": 9,
      "label": "Artículos por página"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 3,
      "label": "Columnas en escritorio"
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "default": true,
      "label": "Mostrar fecha"
    },
    {
      "type": "checkbox",
      "id": "show_author",
      "default": true,
      "label": "Mostrar autor"
    },
    {
      "type": "checkbox",
      "id": "show_excerpt",
      "default": true,
      "label": "Mostrar extracto"
    }
  ]
}
{% endschema %}
