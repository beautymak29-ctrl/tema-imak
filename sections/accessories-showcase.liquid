{%- if section.blocks.size > 0 -%}
<section class="accessories-showcase section-{{ section.id }}" id="section-{{ section.id }}">
  <div class="page-width">

    {%- if section.settings.title != blank -%}
      <h2 class="accessories-showcase__title">{{ section.settings.title }}</h2>
    {%- endif -%}

    <div class="accessories-showcase__grid">
      {%- for block in section.blocks -%}
        <article class="accessories-showcase__card" {{ block.shopify_attributes }}>

          <div class="accessories-showcase__info">
            {%- if block.settings.badge != blank -%}
              <span class="accessories-showcase__badge">{{ block.settings.badge }}</span>
            {%- endif -%}
            <h3 class="accessories-showcase__name">{{ block.settings.name }}</h3>
            {%- if block.settings.description != blank -%}
              <p class="accessories-showcase__desc">{{ block.settings.description }}</p>
            {%- endif -%}
            {%- if block.settings.link != blank and block.settings.link_label != blank -%}
              <a href="{{ block.settings.link }}" class="accessories-showcase__link">
                {{ block.settings.link_label }} &rsaquo;
              </a>
            {%- endif -%}
          </div>

          <div class="accessories-showcase__media">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 700 | image_tag:
                loading: 'lazy',
                widths: '350, 550, 700',
                class: 'accessories-showcase__image'
              }}
            {%- else -%}
              {{ 'product-2' | placeholder_svg_tag: 'accessories-showcase__image accessories-showcase__image--placeholder' }}
            {%- endif -%}
          </div>

        </article>
      {%- endfor -%}
    </div>

  </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "Accesorios destacados",
  "tag": "section",
  "class": "section-accessories-showcase",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título de la sección",
      "default": "Consiente a tu iPhone."
    }
  ],
  "blocks": [
    {
      "type": "accessory",
      "name": "Accesorio",
      "settings": [
        {
          "type": "text",
          "id": "badge",
          "label": "Badge (ej: Nuevo)"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Nombre del accesorio",
          "default": "AirPods"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Descripción",
          "default": "Descubre todos los modelos de AirPods y elige tus favoritos."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagen"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Enlace"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Texto del enlace",
          "default": "Más información"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Accesorios destacados",
      "blocks": [
        {
          "type": "accessory",
          "settings": {
            "name": "AirPods",
            "description": "Descubre todos los modelos de AirPods y elige tus favoritos.",
            "link_label": "Más información"
          }
        },
        {
          "type": "accessory",
          "settings": {
            "badge": "Nuevo",
            "name": "AirTag",
            "description": "Con su bocina más potente y el rango de Rastreo Preciso mejorado, es más fácil que nunca localizar todo lo que te importa.",
            "link_label": "Más información"
          }
        }
      ]
    }
  ]
}
{% endschema %}
