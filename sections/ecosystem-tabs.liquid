{%- if section.blocks.size > 0 -%}
<section class="eco-section section-{{ section.id }}" id="section-{{ section.id }}">
  <div class="page-width">

    {%- if section.settings.title != blank -%}
      <header class="eco-section__header">
        <h2 class="eco-section__title">{{ section.settings.title }}</h2>
      </header>
    {%- endif -%}

    <div class="eco-accordion" id="eco-accordion-{{ section.id }}">
      <div class="eco-accordion__items">
        <ul class="eco-accordion__list" role="list">
          {%- for block in section.blocks -%}
            <li class="eco-accordion__item{% if forloop.first %} eco-accordion__item--expanded{% else %} eco-accordion__item--collapsed{% endif %}" {{ block.shopify_attributes }}>
              <h3 class="eco-accordion__title">
                <button
                  class="eco-accordion__button"
                  aria-expanded="{% if forloop.first %}true{% else %}false{% endif %}"
                  aria-controls="eco-tray-{{ block.id }}"
                  id="eco-btn-{{ block.id }}"
                  data-eco-trigger
                >
                  <span class="eco-accordion__title-text">{{ block.settings.tab_label }}</span>
                  <span class="eco-accordion__icon" aria-hidden="true">
                    <svg viewBox="0 0 17 8.85">
                      <polyline stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" fill="none" points="{% if forloop.first %}15 7.72 8.5 1.13 2 7.72{% else %}15 1.13 8.5 7.72 2 1.13{% endif %}"/>
                    </svg>
                  </span>
                </button>
              </h3>
              <div
                class="eco-accordion__tray"
                id="eco-tray-{{ block.id }}"
                aria-labelledby="eco-btn-{{ block.id }}"
                role="region"
                {% if forloop.first %}{% else %}aria-hidden="true" style="height:0;overflow:hidden"{% endif %}
              >
                <div class="eco-accordion__content">
                  <div class="eco-accordion__copy">
                    {%- if block.settings.text != blank -%}
                      <p class="eco-accordion__text">{{ block.settings.text }}</p>
                    {%- endif -%}
                  </div>
                  <div class="eco-accordion__image-container">
                    {%- if block.settings.image != blank -%}
                      {{ block.settings.image | image_url: width: 900 | image_tag:
                        loading: 'lazy',
                        widths: '450, 700, 900',
                        class: 'eco-accordion__image',
                        alt: block.settings.image.alt | default: block.settings.tab_label
                      }}
                    {%- else -%}
                      {{ 'lifestyle-2' | placeholder_svg_tag: 'eco-accordion__image' }}
                    {%- endif -%}
                  </div>
                </div>
              </div>
            </li>
          {%- endfor -%}
        </ul>
      </div>

      <div class="eco-accordion__image-large" aria-hidden="true">
        {%- for block in section.blocks -%}
          <div class="eco-accordion__large-img{% if forloop.first %} eco-accordion__large-img--visible{% endif %}" data-eco-large="{{ block.id }}">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 900 | image_tag:
                loading: 'lazy',
                widths: '450, 700, 900',
                class: 'eco-accordion__image',
                alt: block.settings.image.alt | default: block.settings.tab_label
              }}
            {%- else -%}
              {{ 'lifestyle-2' | placeholder_svg_tag: 'eco-accordion__image' }}
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    </div>

  </div>
</section>
{%- endif -%}

<script>
(function() {
  var sId = '{{ section.id }}';
  var wrap = document.getElementById('eco-accordion-' + sId);
  if (!wrap) return;
  var items = wrap.querySelectorAll('.eco-accordion__item');
  var largeImgs = wrap.querySelectorAll('.eco-accordion__large-img');

  wrap.addEventListener('click', function(e) {
    var btn = e.target.closest('[data-eco-trigger]');
    if (!btn) return;
    var li = btn.closest('.eco-accordion__item');
    if (!li || li.classList.contains('eco-accordion__item--expanded')) return;

    items.forEach(function(item) {
      var tray = item.querySelector('.eco-accordion__tray');
      var b = item.querySelector('[data-eco-trigger]');
      if (item === li) {
        item.classList.remove('eco-accordion__item--collapsed');
        item.classList.add('eco-accordion__item--expanded');
        b.setAttribute('aria-expanded', 'true');
        tray.removeAttribute('aria-hidden');
        tray.style.height = tray.scrollHeight + 'px';
        setTimeout(function() { tray.style.height = 'auto'; }, 350);
      } else {
        if (item.classList.contains('eco-accordion__item--expanded')) {
          tray.style.height = tray.scrollHeight + 'px';
          tray.offsetHeight;
          tray.style.height = '0';
        }
        item.classList.remove('eco-accordion__item--expanded');
        item.classList.add('eco-accordion__item--collapsed');
        b.setAttribute('aria-expanded', 'false');
        tray.setAttribute('aria-hidden', 'true');
      }
    });

    var blockId = btn.getAttribute('aria-controls').replace('eco-tray-', '');
    largeImgs.forEach(function(img) {
      img.classList.toggle('eco-accordion__large-img--visible', img.getAttribute('data-eco-large') === blockId);
    });
  });
})();
</script>

{% schema %}
{
  "name": "Acordeon ecosistema",
  "tag": "section",
  "class": "section-ecosystem-accordion",
  "settings": [
    { "type": "text", "id": "title", "label": "Titulo", "default": "Siempre bien acompanado." }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Elemento",
      "settings": [
        { "type": "text", "id": "tab_label", "label": "Titulo del acordeon", "default": "iPhone y Mac" },
        { "type": "textarea", "id": "text", "label": "Texto", "default": "Con Duplicacion del iPhone puedes ver la pantalla de tu telefono en la Mac y controlarlo a distancia." },
        { "type": "image_picker", "id": "image", "label": "Imagen" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Acordeon ecosistema",
      "blocks": [
        { "type": "tab", "settings": { "tab_label": "iPhone y Mac", "text": "Con Duplicacion del iPhone puedes ver la pantalla de tu telefono en la Mac y controlarlo a distancia. Las funcionalidades de Continuidad te permiten contestar llamadas y mensajes directamente desde la Mac." } },
        { "type": "tab", "settings": { "tab_label": "iPhone y Apple Watch", "text": "Con el Apple Watch y el iPhone trabajando juntos, puedes cuidar tu salud, hacer seguimiento de tu actividad y mantener todo sincronizado." } },
        { "type": "tab", "settings": { "tab_label": "iPhone y AirPods", "text": "Configura tus AirPods en el iPhone con un simple toque. Y disfruta el Audio Adaptativo, que regula automaticamente el control de ruido." } }
      ]
    }
  ]
}
{% endschema %}
