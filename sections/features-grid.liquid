{%- if section.blocks.size > 0 -%}
<section class="fg-section section-{{ section.id }}" id="section-{{ section.id }}">

  <div class="page-width">
    <header class="fg-header">
      {%- if section.settings.title != blank -%}
        <h2 class="fg-title">{{ section.settings.title }}</h2>
      {%- endif -%}
    </header>
  </div>

  <div class="fg-gallery" id="fg-gallery-{{ section.id }}">
    <div class="fg-gallery__scroll" id="fg-scroll-{{ section.id }}">
      <ul class="fg-gallery__list" role="list">
        {%- for block in section.blocks -%}
          <li class="fg-card{% if forloop.first %} fg-card--current{% endif %}" role="listitem" {{ block.shopify_attributes }}>
            <button type="button" class="fg-card__inner fg-card__inner--clickable" aria-label="{{ block.settings.heading | default: block.settings.category }}, más información" data-fg-open="{{ block.id }}">
              <div class="fg-card__text">
                {%- if block.settings.category != blank -%}
                  <h3 class="fg-card__cat">{{ block.settings.category }}</h3>
                {%- endif -%}
                {%- if block.settings.heading != blank -%}
                  <p class="fg-card__heading">{{ block.settings.heading }}</p>
                {%- endif -%}
              </div>
              <figure class="fg-card__media">
                {%- if block.settings.image != blank -%}
                  {{ block.settings.image | image_url: width: 600 | image_tag:
                    loading: 'lazy',
                    widths: '300, 450, 600',
                    class: 'fg-card__img',
                    alt: block.settings.image.alt | default: block.settings.category
                  }}
                {%- else -%}
                  {{ 'lifestyle-1' | placeholder_svg_tag: 'fg-card__img' }}
                {%- endif -%}
              </figure>
              <span class="fg-card__plus" aria-hidden="true">
                <span class="fg-card__plus-icon">
                  <svg viewBox="0 0 36 36">
                    <path d="m24 16.5h-4.5v-4.5c0-.8286-.6719-1.5-1.5-1.5s-1.5.6714-1.5 1.5v4.5h-4.5c-.8281 0-1.5.6714-1.5 1.5s.6719 1.5 1.5 1.5h4.5v4.5c0 .8286.6719 1.5 1.5 1.5s1.5-.6714 1.5-1.5v-4.5h4.5c.8281 0 1.5-.6714 1.5-1.5s-.6719-1.5-1.5-1.5z"/>
                  </svg>
                </span>
              </span>
            </button>
          </li>
        {%- endfor -%}
      </ul>
    </div>

    <div class="fg-paddlenav">
      <button class="fg-paddle fg-paddle--prev" aria-label="Tarjeta anterior" disabled>
        <svg viewBox="0 0 36 36" aria-hidden="true"><path d="m20 25c-.3838 0-.7676-.1465-1.0605-.4395l-5.5-5.5c-.5859-.5854-.5859-1.5356 0-2.1211l5.5-5.5c.5859-.5859 1.5352-.5859 2.1211 0 .5859.5854.5859 1.5356 0 2.1211l-4.4395 4.4395 4.4395 4.4395c.5859.5854.5859 1.5356 0 2.1211-.293.293-.6768.4395-1.0605.4395z"/></svg>
      </button>
      <button class="fg-paddle fg-paddle--next" aria-label="Siguiente tarjeta">
        <svg viewBox="0 0 36 36" aria-hidden="true"><path d="m22.5597 16.9375-5.5076-5.5c-.5854-.5854-1.5323-.5825-2.1157.0039-.5835.5869-.5815 1.5366.0039 2.1211l4.4438 4.4375-4.4438 4.4375c-.5854.5845-.5874 1.5342-.0039 2.1211.2922.2944.676.4414 1.0598.4414.3818 0 .7637-.1455 1.0559-.4375l5.5076-5.5c.2815-.2812.4403-.6636.4403-1.0625s-.1588-.7812-.4403-1.0625z"/></svg>
      </button>
    </div>
  </div>

</section>

{%- comment -%} Modal de funcionalidades {%- endcomment -%}
<div class="fg-modal" id="fg-modal-{{ section.id }}" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Información detallada">
  <div class="fg-modal__overlay" data-fg-close></div>
  <div class="fg-modal__dialog">
    <button class="fg-modal__close" type="button" data-fg-close aria-label="Cerrar">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M1 1l16 16M17 1L1 17" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
    </button>
    <div class="fg-modal__body">
      {%- for block in section.blocks -%}
        <div class="fg-modal__content" id="fg-modal-content-{{ block.id }}" hidden>
          {%- if block.settings.modal_heading != blank -%}
            <h2 class="fg-modal__heading">{{ block.settings.modal_heading | escape }}</h2>
          {%- else -%}
            <h2 class="fg-modal__heading">{{ block.settings.heading | escape }}</h2>
          {%- endif -%}
          {%- comment -%} Par 1: descripción + imagen {%- endcomment -%}
          {%- if block.settings.modal_description != blank or block.settings.modal_image_1 != blank -%}
            <div class="fg-modal__pair">
              {%- if block.settings.modal_description != blank -%}
                <div class="fg-modal__text rte">{{ block.settings.modal_description }}</div>
              {%- endif -%}
              {%- if block.settings.modal_image_1 != blank -%}
                <div class="fg-modal__pair-img-wrap">
                  {{ block.settings.modal_image_1 | image_url: width: 900 | image_tag: loading: 'lazy', class: 'fg-modal__pair-img', alt: block.settings.modal_image_1.alt | default: block.settings.heading }}
                </div>
              {%- endif -%}
            </div>
          {%- endif -%}

          {%- comment -%} Par 2: descripción + imagen {%- endcomment -%}
          {%- if block.settings.modal_description_2 != blank or block.settings.modal_image_2 != blank -%}
            <div class="fg-modal__pair">
              {%- if block.settings.modal_description_2 != blank -%}
                <div class="fg-modal__text rte">{{ block.settings.modal_description_2 }}</div>
              {%- endif -%}
              {%- if block.settings.modal_image_2 != blank -%}
                <div class="fg-modal__pair-img-wrap">
                  {{ block.settings.modal_image_2 | image_url: width: 900 | image_tag: loading: 'lazy', class: 'fg-modal__pair-img', alt: block.settings.modal_image_2.alt | default: block.settings.heading }}
                </div>
              {%- endif -%}
            </div>
          {%- endif -%}

          {%- comment -%} Par 3: descripción + imagen {%- endcomment -%}
          {%- if block.settings.modal_description_3 != blank or block.settings.modal_image_3 != blank -%}
            <div class="fg-modal__pair">
              {%- if block.settings.modal_description_3 != blank -%}
                <div class="fg-modal__text rte">{{ block.settings.modal_description_3 }}</div>
              {%- endif -%}
              {%- if block.settings.modal_image_3 != blank -%}
                <div class="fg-modal__pair-img-wrap">
                  {{ block.settings.modal_image_3 | image_url: width: 900 | image_tag: loading: 'lazy', class: 'fg-modal__pair-img', alt: block.settings.modal_image_3.alt | default: block.settings.heading }}
                </div>
              {%- endif -%}
            </div>
          {%- endif -%}
          {%- if block.settings.link != blank -%}
            <a href="{{ block.settings.link }}" class="btn fg-modal__cta">{{ block.settings.link_label | default: 'Más información' | escape }}</a>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{%- endif -%}

<script>
(function() {
  var sId = '{{ section.id }}';
  var scrollEl = document.getElementById('fg-scroll-' + sId);
  var galleryEl = document.getElementById('fg-gallery-' + sId);
  if (!scrollEl || !galleryEl) return;
  var prevBtn = galleryEl.querySelector('.fg-paddle--prev');
  var nextBtn = galleryEl.querySelector('.fg-paddle--next');
  function scrollAmount() {
    var c = scrollEl.querySelector('.fg-card');
    if (!c) return 340;
    return c.offsetWidth + parseInt(getComputedStyle(c).marginRight || 16);
  }
  function syncButtons() {
    if (prevBtn) prevBtn.disabled = scrollEl.scrollLeft <= 4;
    if (nextBtn) nextBtn.disabled = scrollEl.scrollLeft >= scrollEl.scrollWidth - scrollEl.clientWidth - 4;
  }
  if (prevBtn) prevBtn.addEventListener('click', function() { scrollEl.scrollBy({ left: -scrollAmount() * 2, behavior: 'smooth' }); });
  if (nextBtn) nextBtn.addEventListener('click', function() { scrollEl.scrollBy({ left: scrollAmount() * 2, behavior: 'smooth' }); });
  scrollEl.addEventListener('scroll', syncButtons, { passive: true });
  window.addEventListener('resize', syncButtons);
  syncButtons();

  /* ---- Modal ---- */
  var modal = document.getElementById('fg-modal-' + sId);
  if (!modal) return;
  function openModal(blockId) {
    modal.querySelectorAll('.fg-modal__content').forEach(function(c) { c.hidden = true; });
    var content = document.getElementById('fg-modal-content-' + blockId);
    if (content) content.hidden = false;
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    var closeBtn = modal.querySelector('.fg-modal__close');
    if (closeBtn) closeBtn.focus();
  }
  function closeModal() {
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }
  var sectionEl = document.getElementById('section-' + sId);
  if (sectionEl) {
    sectionEl.querySelectorAll('[data-fg-open]').forEach(function(btn) {
      btn.addEventListener('click', function() { openModal(btn.getAttribute('data-fg-open')); });
    });
  }
  modal.querySelectorAll('[data-fg-close]').forEach(function(el) {
    el.addEventListener('click', closeModal);
  });
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && modal.getAttribute('aria-hidden') === 'false') closeModal();
  });
})();
</script>

{% schema %}
{
  "name": "Grid de funcionalidades",
  "tag": "section",
  "class": "section-features-grid",
  "settings": [
    { "type": "text", "id": "title", "label": "Titulo de la seccion", "default": "Descubre el iPhone." }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Funcionalidad",
      "settings": [
        { "type": "text", "id": "category", "label": "Categoria", "default": "Innovacion" },
        { "type": "text", "id": "heading", "label": "Titulo de la tarjeta", "default": "Disenado para durar. Y enamorar." },
        { "type": "image_picker", "id": "image", "label": "Imagen de la tarjeta" },
        { "type": "header", "content": "Modal - Mas informacion" },
        { "type": "text", "id": "modal_heading", "label": "Titulo del modal (deja vacio para usar el titulo de la tarjeta)" },
        { "type": "richtext", "id": "modal_description", "label": "Descripcion 1" },
        { "type": "image_picker", "id": "modal_image_1", "label": "Imagen 1" },
        { "type": "header", "content": "Par 2" },
        { "type": "richtext", "id": "modal_description_2", "label": "Descripcion 2" },
        { "type": "image_picker", "id": "modal_image_2", "label": "Imagen 2" },
        { "type": "header", "content": "Par 3" },
        { "type": "richtext", "id": "modal_description_3", "label": "Descripcion 3" },
        { "type": "image_picker", "id": "modal_image_3", "label": "Imagen 3" },
        { "type": "url", "id": "link", "label": "Enlace del boton" },
        { "type": "text", "id": "link_label", "label": "Texto del boton", "default": "Mas informacion" }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Grid de funcionalidades",
      "blocks": [
        { "type": "feature", "settings": { "category": "Innovacion", "heading": "Disenado para durar. Y enamorar." } },
        { "type": "feature", "settings": { "category": "Camaras de ultima generacion", "heading": "Haz fotos sonadas y videos de pelicula." } },
        { "type": "feature", "settings": { "category": "Chip y bateria", "heading": "Velocidad para rato." } },
        { "type": "feature", "settings": { "category": "iOS y Apple Intelligence", "heading": "Estrenando look. Derrochando magia." } },
        { "type": "feature", "settings": { "category": "Medio ambiente", "heading": "Disenado pensando en el planeta." } },
        { "type": "feature", "settings": { "category": "Privacidad", "heading": "Tus datos siempre bajo tu control." } },
        { "type": "feature", "settings": { "category": "Tranquilidad", "heading": "Funcionalidades de seguridad. Siempre bienvenidas." } }
      ]
    }
  ]
}
{% endschema %}
