{%- if section.blocks.size > 0 -%}
<section class="features-grid section-{{ section.id }}" id="section-{{ section.id }}">
  <div class="page-width">

    {%- if section.settings.title != blank -%}
      <h2 class="features-grid__title">{{ section.settings.title }}</h2>
    {%- endif -%}

    <div class="features-grid__grid">
      {%- for block in section.blocks -%}
        <article
          class="features-grid__card features-grid__card--{{ block.settings.bg_style }}{% if block.settings.full_width %} features-grid__card--full{% endif %}"
          {{ block.shopify_attributes }}
        >
          <div class="features-grid__card-text">
            {%- if block.settings.category != blank -%}
              <span class="features-grid__category">{{ block.settings.category }}</span>
            {%- endif -%}
            <h3 class="features-grid__heading">{{ block.settings.heading }}</h3>
            {%- if block.settings.text != blank -%}
              <p class="features-grid__desc">{{ block.settings.text }}</p>
            {%- endif -%}
            {%- if block.settings.link != blank and block.settings.link_label != blank -%}
              <a href="{{ block.settings.link }}" class="features-grid__link">
                {{ block.settings.link_label }} &rsaquo;
              </a>
            {%- endif -%}
          </div>

          <div class="features-grid__media">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 800 | image_tag:
                loading: 'lazy',
                widths: '400, 600, 800',
                class: 'features-grid__image'
              }}
            {%- else -%}
              {{ 'lifestyle-1' | placeholder_svg_tag: 'features-grid__image features-grid__image--placeholder' }}
            {%- endif -%}
          </div>
        </article>
      {%- endfor -%}
    </div>

  </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "Grid de funcionalidades",
  "tag": "section",
  "class": "section-features-grid",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título de la sección",
      "default": "Descubre el iPhone."
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Funcionalidad",
      "settings": [
        {
          "type": "text",
          "id": "category",
          "label": "Categoría (etiqueta pequeña)",
          "default": "Innovación"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Título",
          "default": "Diseñado para durar. Y enamorar."
        },
        {
          "type": "text",
          "id": "text",
          "label": "Descripción"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagen"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Enlace"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Texto del enlace",
          "default": "Más información"
        },
        {
          "type": "checkbox",
          "id": "full_width",
          "label": "Ancho completo (ocupa las 2 columnas)",
          "default": false
        },
        {
          "type": "select",
          "id": "bg_style",
          "label": "Estilo de fondo",
          "options": [
            { "value": "dark",  "label": "Oscuro" },
            { "value": "light", "label": "Claro" },
            { "value": "gray",  "label": "Gris claro" }
          ],
          "default": "light"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Grid de funcionalidades",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "category": "Innovación",
            "heading": "Diseñado para durar. Y enamorar.",
            "link_label": "Más información",
            "bg_style": "dark"
          }
        },
        {
          "type": "feature",
          "settings": {
            "category": "Cámaras de última generación",
            "heading": "Haz fotos soñadas y videos de película.",
            "link_label": "Más información",
            "bg_style": "light"
          }
        },
        {
          "type": "feature",
          "settings": {
            "category": "Chip y batería",
            "heading": "Velocidad para rato.",
            "link_label": "Más información",
            "bg_style": "light"
          }
        },
        {
          "type": "feature",
          "settings": {
            "category": "iOS y Apple Intelligence",
            "heading": "Estrenando look. Derrochando magia.",
            "link_label": "Más información",
            "bg_style": "dark"
          }
        },
        {
          "type": "feature",
          "settings": {
            "category": "Medio ambiente",
            "heading": "Diseñado pensando en el planeta.",
            "link_label": "Más información",
            "bg_style": "gray"
          }
        },
        {
          "type": "feature",
          "settings": {
            "category": "Privacidad",
            "heading": "Tus datos siempre bajo tu control.",
            "link_label": "Más información",
            "bg_style": "gray"
          }
        }
      ]
    }
  ]
}
{% endschema %}
