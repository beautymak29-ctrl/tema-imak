[
  {
    "name": "theme_info",
    "theme_name": "Tema Imak",
    "theme_version": "1.1.0",
    "theme_author": "Imak",
    "theme_documentation_url": "https://github.com/beautymak29-ctrl/tema-imak",
    "theme_support_url": "https://github.com/beautymak29-ctrl/tema-imak/issues"
  },
  {
    "name": "Esquemas de color",
    "settings": [
      {
        "type": "color_scheme_group",
        "id": "color_schemes",
        "definition": [
          {
            "type": "color",
            "id": "background",
            "label": "Fondo",
            "default": "#ffffff"
          },
          {
            "type": "color_background",
            "id": "background_gradient",
            "label": "Degradado de fondo"
          },
          {
            "type": "color",
            "id": "text_color",
            "label": "Texto",
            "default": "#121212"
          },
          {
            "type": "color",
            "id": "heading_color",
            "label": "Encabezados",
            "default": "#121212"
          },
          {
            "type": "color",
            "id": "primary_color",
            "label": "Color primario",
            "default": "#121212"
          },
          {
            "type": "color",
            "id": "border_color",
            "label": "Bordes",
            "default": "#e5e5e5"
          },
          {
            "type": "color",
            "id": "btn_background",
            "label": "Fondo del botón",
            "default": "#121212"
          },
          {
            "type": "color",
            "id": "btn_color",
            "label": "Texto del botón",
            "default": "#ffffff"
          },
          {
            "type": "color",
            "id": "btn_background_hover",
            "label": "Fondo del botón (hover)",
            "default": "#333333"
          },
          {
            "type": "color",
            "id": "btn_color_hover",
            "label": "Texto del botón (hover)",
            "default": "#ffffff"
          }
        ],
        "role": {
          "background": "background",
          "text": "text_color",
          "primary_button": "btn_background",
          "on_primary_button": "btn_color",
          "primary_button_border": "btn_background",
          "secondary_button": "background",
          "on_secondary_button": "text_color",
          "secondary_button_border": "border_color",
          "links": "primary_color",
          "icons": "text_color"
        }
      },
      {
        "type": "color_scheme",
        "id": "color_scheme",
        "default": "scheme-1",
        "label": "Esquema de color"
      }
    ]
  },
  {
    "name": "Tipografía",
    "settings": [
      {
        "type": "font_picker",
        "id": "type_body_font",
        "label": "Fuente del cuerpo",
        "default": "assistant_n4"
      },
      {
        "type": "font_picker",
        "id": "type_header_font",
        "label": "Fuente de encabezados",
        "default": "assistant_n4"
      },
      {
        "type": "range",
        "id": "heading_font_scale",
        "min": 70,
        "max": 150,
        "step": 5,
        "unit": "%",
        "label": "Escala de encabezados",
        "default": 100
      }
    ]
  },
  {
    "name": "Botones",
    "settings": [
      {
        "type": "range",
        "id": "button_radius",
        "min": 0,
        "max": 40,
        "step": 2,
        "unit": "px",
        "label": "Radio del botón",
        "default": 2
      },
      {
        "type": "select",
        "id": "btn_text_transform",
        "label": "Transformación de texto",
        "options": [
          { "value": "none", "label": "Normal" },
          { "value": "uppercase", "label": "MAYÚSCULAS" },
          { "value": "capitalize", "label": "Capitalizado" }
        ],
        "default": "uppercase"
      }
    ]
  },
  {
    "name": "Diseño",
    "settings": [
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon"
      },
      {
        "type": "range",
        "id": "page_width",
        "min": 1000,
        "max": 1600,
        "step": 100,
        "unit": "px",
        "label": "Ancho de página",
        "default": 1200
      },
      {
        "type": "range",
        "id": "border_radius",
        "min": 0,
        "max": 20,
        "step": 1,
        "unit": "px",
        "label": "Radio de bordes",
        "default": 4
      },
      {
        "type": "range",
        "id": "spacing_grid_vertical",
        "min": 0,
        "max": 36,
        "step": 4,
        "unit": "px",
        "label": "Espaciado vertical de cuadrícula",
        "default": 8
      },
      {
        "type": "range",
        "id": "spacing_grid_horizontal",
        "min": 0,
        "max": 36,
        "step": 4,
        "unit": "px",
        "label": "Espaciado horizontal de cuadrícula",
        "default": 8
      },
      {
        "type": "range",
        "id": "section_spacing_desktop",
        "min": 20,
        "max": 120,
        "step": 4,
        "unit": "px",
        "label": "Espaciado de secciones (escritorio)",
        "default": 64
      },
      {
        "type": "range",
        "id": "section_spacing_mobile",
        "min": 16,
        "max": 80,
        "step": 4,
        "unit": "px",
        "label": "Espaciado de secciones (móvil)",
        "default": 40
      }
    ]
  },
  {
    "name": "Idioma y accesibilidad",
    "settings": [
      {
        "type": "checkbox",
        "id": "rtl_enable",
        "label": "Activar RTL (derecha a izquierda)",
        "default": false
      },
      {
        "type": "text",
        "id": "rtl_languages",
        "label": "Códigos de idioma RTL (separados por coma)",
        "info": "Ejemplo: ar,he,fa"
      }
    ]
  }
]
