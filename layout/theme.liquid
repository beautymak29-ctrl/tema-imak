{%- liquid
  assign enable_rtl = settings.rtl_enable
  assign iso_code = request.locale.iso_code
  if settings.rtl_languages != blank
    if settings.rtl_languages contains iso_code
      assign enable_rtl = true
    else
      assign enable_rtl = false
    endif
  endif
-%}
<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}"{% if enable_rtl %} dir="rtl"{% endif %}>
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="theme-color" content="">

    <link rel="canonical" href="{{ canonical_url }}">

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    {%- unless settings.type_body_font.system? and settings.type_header_font.system? -%}
      <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
    {%- endunless -%}

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; {{ 'general.meta.page' | t: page: current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {%- if page_description -%}
      <meta name="description" content="{{ page_description | escape }}">
    {%- endif -%}

    {%- render 'meta-tags' -%}

    {%- comment -%} Preload de la imagen hero para reducir LCP {%- endcomment -%}
    {%- if template.name == 'index' or template.suffix == 'ipad' or template.suffix == 'mac' or template.suffix == 'watch' or template.suffix == 'imac' or template.suffix == 'airpods' -%}
      {%- assign hero_s = sections['hero-banner'] -%}
      {%- if hero_s.settings.image != blank -%}
        <link rel="preload" as="image"
          href="{{ hero_s.settings.image | image_url: width: 1500 }}"
          imagesrcset="{{ hero_s.settings.image | image_url: width: 750 }} 750w,
                       {{ hero_s.settings.image | image_url: width: 1100 }} 1100w,
                       {{ hero_s.settings.image | image_url: width: 1500 }} 1500w"
          imagesizes="100vw"
        >
      {%- endif -%}
    {%- endif -%}

    {{ content_for_header }}

    {%- render 'font-variables' -%}

    {%- style -%}
      {%- for scheme in settings.color_schemes -%}
        {%- assign scheme_classes = scheme_classes | append: ', .color-' | append: scheme.id -%}
        {%- if forloop.index == 1 -%}:root,{%- endif -%}
        .color-{{ scheme.id }} {
          --color-background: {{ scheme.settings.background }};
          {%- if scheme.settings.background_gradient != empty -%}
            --gradient-background: {{ scheme.settings.background_gradient }};
          {%- else -%}
            --gradient-background: {{ scheme.settings.background }};
          {%- endif -%}
          --color-text: {{ scheme.settings.text_color }};
          --color-text-rgb: {{ scheme.settings.text_color.red }}, {{ scheme.settings.text_color.green }}, {{ scheme.settings.text_color.blue }};
          --color-heading: {{ scheme.settings.heading_color }};
          --color-heading-rgb: {{ scheme.settings.heading_color.red }}, {{ scheme.settings.heading_color.green }}, {{ scheme.settings.heading_color.blue }};
          --color-primary: {{ scheme.settings.primary_color }};
          --color-primary-rgb: {{ scheme.settings.primary_color.red }}, {{ scheme.settings.primary_color.green }}, {{ scheme.settings.primary_color.blue }};
          --color-border: {{ scheme.settings.border_color }};
          --btn-primary-bg: {{ scheme.settings.btn_background }};
          --btn-primary-color: {{ scheme.settings.btn_color }};
          --btn-primary-bg-hover: {{ scheme.settings.btn_background_hover }};
          --btn-primary-color-hover: {{ scheme.settings.btn_color_hover }};
        }
      {%- endfor -%}

      {{ scheme_classes | prepend: 'body' }} {
        color: var(--color-text);
        background-color: var(--color-background);
      }

      :root {
        --font-body-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
        --font-body-style: {{ settings.type_body_font.style }};
        --font-body-weight: {{ settings.type_body_font.weight }};
        --font-heading-family: {{ settings.type_header_font.family }}, {{ settings.type_header_font.fallback_families }};
        --font-heading-style: {{ settings.type_header_font.style }};
        --font-heading-weight: {{ settings.type_header_font.weight }};

        --page-width: {{ settings.page_width | divided_by: 10 }}rem;
        --grid-desktop-vertical-spacing: {{ settings.spacing_grid_vertical }}px;
        --grid-desktop-horizontal-spacing: {{ settings.spacing_grid_horizontal }}px;
        --grid-mobile-vertical-spacing: {{ settings.spacing_grid_vertical | divided_by: 2 }}px;
        --grid-mobile-horizontal-spacing: {{ settings.spacing_grid_horizontal | divided_by: 2 }}px;

        --btn-radius: {{ settings.button_radius }}px;
        --btn-text-transform: {{ settings.btn_text_transform }};

        --section-spacing-desktop: {{ settings.section_spacing_desktop }}px;
        --section-spacing-mobile: {{ settings.section_spacing_mobile }}px;

        --heading-font-scale: {{ settings.heading_font_scale | divided_by: 100.0 }};
        --h1-size: calc(var(--heading-font-scale) * 4rem);
        --h2-size: calc(var(--heading-font-scale) * 3.2rem);
        --h3-size: calc(var(--heading-font-scale) * 2.4rem);
        --h4-size: calc(var(--heading-font-scale) * 2rem);
        --h5-size: calc(var(--heading-font-scale) * 1.6rem);

        --transition: 0.3s ease;
        --overlay-bg: rgba(0, 0, 0, 0.5);
        --border-radius-base: {{ settings.border_radius }}px;
      }

      @media (max-width: 749px) {
        :root {
          --section-spacing: var(--section-spacing-mobile);
        }
      }
      @media (min-width: 750px) {
        :root {
          --section-spacing: var(--section-spacing-desktop);
        }
      }
    {%- endstyle -%}

    {{- 'base.css' | asset_url | stylesheet_tag -}}

    {%- if request.design_mode -%}
      <script>document.documentElement.classList.add('shopify-design-mode');</script>
    {%- endif -%}

    <script>
      document.documentElement.className = document.documentElement.className.replace('no-js', 'js');
    </script>
  </head>

  <body class="gradient color-{{ settings.color_scheme }}{% if enable_rtl %} rtl{% endif %} {{ request.page_type }}">

    {%- sections 'header-group' -%}

    <main id="MainContent" class="content-for-layout focus-none" role="main" tabindex="-1">
      {%- if template.name == 'index' or template.suffix == 'ipad' or template.suffix == 'mac' or template.suffix == 'watch' or template.suffix == 'imac' or template.suffix == 'airpods' -%}
        {%- section 'hero-banner' -%}
      {%- endif -%}
      {{ content_for_layout }}
    </main>

    {%- sections 'footer-group' -%}

    <script src="{{ 'global.js' | asset_url }}" defer="defer"></script>
  </body>
</html>
